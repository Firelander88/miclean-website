# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: error | warn | info | http | debug
LOG_LEVEL=debug

# ── Email (optional — leave blank to disable email notifications) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL=info@micleangroup.az

# ── Admin ─────────────────────────────────────────────────────────────────────
# Generate a strong random key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=change-this-to-a-strong-random-secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your domain in production, e.g.: https://micleangroup.az
ALLOWED_ORIGIN=*
