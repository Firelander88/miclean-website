{
  "name": "miclean-group-website",
  "version": "1.1.0",
  "description": "MI CLEAN GROUP MMC – 5 Ulduzlu Otel Sektoru Kataloq & Sifariş Platforması",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "knex --knexfile db/knexfile.js migrate:latest",
    "db:rollback": "knex --knexfile db/knexfile.js migrate:rollback",
    "db:seed": "knex --knexfile db/knexfile.js seed:run",
    "db:reset": "npm run db:rollback -- --all && npm run db:migrate && npm run db:seed",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop miclean-website",
    "pm2:restart": "pm2 restart miclean-website",
    "pm2:logs": "pm2 logs miclean-website",
    "pm2:monit": "pm2 monit"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
