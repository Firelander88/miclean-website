{"embedId":"4e450914-44ab-40b6-a91a-22ac8cbf4bad","html":"\n\n<!-- İSTEHLAK -->\n<section class=\"sec\" id=\"istehlak\">\n  <div class=\"sec-top rv\">\n    <div>\n      <div style=\"margin-bottom:14px\"><span class=\"eyebrow\" style=\"display:inline-flex;margin:0\">05 / İstehlak</span> <span class=\"tag\">234 Məhsul · 48 Alt Kateqoriya</span></div>\n      <h2 class=\"h2\">İstehlak <b>Materialları</b></h2>\n    </div>\n    <p class=\"sec-desc\">Kağız məhsullar, F&amp;B qablar, dispenser sistemləri, zibil qabları, PPE. Otelin hər günlük ehtiyacı üçün.</p>\n  </div>\n\n  <div class=\"sub rv\">Kağız Məhsullar <big>Sanitar · Restoran · Otaq</big></div>\n  <div class=\"tbl-w rv\">\n    <table class=\"tbl\">\n      <thead><tr><th>Məhsul</th><th>Keyfiyyət</th><th>Format</th><th>İstifadə</th></tr></thead>\n      <tbody>\n        <tr><td class=\"tn\">Kağız dəsmal — rulon</td><td class=\"tm\">1-ply / 2-ply / Recycled</td><td class=\"tm\">Rulon / Qutu</td><td class=\"tm\">Sanitar · Mətbəx</td></tr>\n        <tr><td class=\"tn\">Tualet kağızı — jumbo roll</td><td class=\"tm\">1-ply / 2-ply / Recycled</td><td class=\"tm\">Rulon / Qutu</td><td class=\"tm\">Sanitar qovşağı</td></tr>\n        <tr><td class=\"tn\">Logo çaplı salfet</td><td class=\"tm\">1-ply / 2-ply / Recycled</td><td class=\"tm\">Paket / Qutu</td><td class=\"tm\">Restoran / Bar · Konfrans</td></tr>\n        <tr><td class=\"tn\">Üz salfeti (facial tissue)</td><td class=\"tm\">1-ply / 2-ply / Recycled</td><td class=\"tm\">Qutu</td><td class=\"tm\">Otaq · Lobby</td></tr>\n        <tr><td class=\"tn\">Tualet oturacaq örtüyü</td><td class=\"tm\">1-ply / 2-ply / Recycled</td><td class=\"tm\">Paket / Qutu</td><td class=\"tm\">Sanitar qovşağı</td></tr>\n      </tbody>\n    </table>\n  </div>\n\n  <div class=\"sub rv\">F&amp;B Qablar <big>Alüminium · Karton · Bio</big></div>\n  <div class=\"pg rv\">\n<div class=\"pc\"><img class=\"pc-img\" width=\"600\" height=\"152\" src=\"https://images.unsplash.com/photo-1594212699903-ec8a3eca50f5?w=600&q=75\" alt=\"Alüminium qida qabları paketləmə\" loading=\"lazy\" onerror=\"this.style.display='none'\"><div class=\"pc-body\"><div class=\"pc-name\">Alüminium Qablar + Qapaq</div><div class=\"pc-hr\"></div><ul class=\"pc-ul\"><li>250 / 350 / 500 / 750 gr</li><li>1000 / 1500 gr həcmlər</li><li>İki &amp; üç göz bölmə</li></ul><div class=\"pc-foot\"><span class=\"pc-pkg\">📦 Koli / 100 ədəd</span><span class=\"pc-del\">5–7 gün</span></div></div></div>\n<div class=\"pc\"><img class=\"pc-img\" width=\"600\" height=\"152\" src=\"https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=600&q=75\" alt=\"Birdəfəlik kağız qəhvə stəkanları\" loading=\"lazy\" onerror=\"this.style.display='none'\"><div class=\"pc-body\"><div class=\"pc-name\">Karton Stəkan — 8 OZ / 12 OZ</div><div class=\"pc-hr\"></div><ul class=\"pc-ul\"><li>Sadə / Double / Ripple</li><li>Ağ / Qara / Kraft dizayn</li><li>500 – 1000 ədəd / koli</li></ul><div class=\"pc-foot\"><span class=\"pc-pkg\">📦 Koli</span><span class=\"pc-del\">5–7 gün</span></div></div></div>\n<div class=\"pc\"><img class=\"pc-img\" width=\"600\" height=\"152\" src=\"https://images.unsplash.com/photo-1581783898382-80983a0d3b67?w=600&q=75\" alt=\"Bio çəngəl qaşıq bıçaq — ekoloji\" loading=\"lazy\" onerror=\"this.style.display='none'\"><div class=\"pc-body\"><div class=\"pc-name\">Bio Çəngəl / Qaşıq / Bıçaq Seti</div><div class=\"pc-hr\"></div><ul class=\"pc-ul\"><li>Compostable polymer</li><li>EN13432 standartı</li><li>Salfet ilə birlikdə set</li></ul><div class=\"pc-foot\"><span class=\"pc-pkg\">📦 Paket / Qutu</span><span class=\"pc-del\">5–7 gün</span></div></div></div>\n<div class=\"pc\"><img class=\"pc-img\" width=\"600\" height=\"152\" src=\"https://images.unsplash.com/photo-1513104890138-7c749659a591?w=600&q=75\" alt=\"Pizza qutusu qablaşdırma\" loading=\"lazy\" onerror=\"this.style.display='none'\"><div class=\"pc-body\"><div class=\"pc-name\">Pizza / Pide Qutuları</div><div class=\"pc-hr\"></div><ul class=\"pc-ul\"><li>Pizza: 25×25 / 30×30 / 33×33</li><li>Şəkilli dizayn mövcuddur</li><li>Pide qutusu ayrıca var</li></ul><div class=\"pc-foot\"><span class=\"pc-pkg\">📦 Koli</span><span class=\"pc-del\">5–7 gün</span></div></div></div>\n  </div>\n\n  <div class=\"sub rv\">Dispenser &amp; Avadanlıq <big>Sensor · Manuel · Krom</big></div>\n  <div class=\"tbl-w rv\">\n    <table class=\"tbl\">\n      <thead><tr><th>Avadanlıq</th><th>Brand</th><th>Xüsusiyyət</th></tr></thead>\n      <tbody>\n        <tr><td class=\"tn\">Sensor kağız havlu dispenseri</td><td class=\"tm\">Carpex</td><td class=\"tm\">Autocut / Manuel</td></tr>\n        <tr><td class=\"tn\">Sensor köpük sabun aparatı</td><td class=\"tm\">Carpex</td><td class=\"tm\">1000 ml</td></tr>\n        <tr><td class=\"tn\">Tekçek tualet kağızı dispenseri</td><td class=\"tm\">Rulopak</td><td class=\"tm\">Maxi / Mini — Qara</td></tr>\n        <tr><td class=\"tn\">Z katlama kağız aparatı</td><td class=\"tm\">Rulopak / Vialli</td><td class=\"tm\">200 vərəqlik</td></tr>\n        <tr><td class=\"tn\">Dispenser peçete aparatı</td><td class=\"tm\">Palex</td><td class=\"tm\">Ağ / Krom / Qara</td></tr>\n        <tr><td class=\"tn\">Sensor əl quruducu 2000W</td><td class=\"tm\">Palex</td><td class=\"tm\">Krom / Normal</td></tr>\n        <tr><td class=\"tn\">Professional qoxu maşını</td><td class=\"tm\">Rulopak Cosmic M5</td><td class=\"tm\">Timer + intensivlik</td></tr>\n      </tbody>\n    </table>\n  </div>\n\n  <div class=\"sub rv\">PPE &amp; Qoruyucu Geyim <big>Əlcək · Maska · Bone</big></div>\n  <div class=\"tbl-w rv\">\n    <table class=\"tbl\">\n      <thead><tr><th>Məhsul</th><th>Material</th><th>Ölçü / Paket</th></tr></thead>\n      <tbody>\n        <tr><td class=\"tn\">Latex əlcək pudralı/pudrasız</td><td class=\"tm\">Latex</td><td class=\"tm\">N100 · S/M/L/XL</td></tr>\n        <tr><td class=\"tn\">Nitril əlcək mavi/qara</td><td class=\"tm\">Nitril — pudrasız</td><td class=\"tm\">N100 · Kimyəvi uyğun</td></tr>\n        <tr><td class=\"tn\">Tibbi maska</td><td class=\"tm\">3 qatlı nonwoven</td><td class=\"tm\">50-li paket</td></tr>\n        <tr><td class=\"tn\">PE öndəlik</td><td class=\"tm\">Polyethylene</td><td class=\"tm\">100-lü paket</td></tr>\n        <tr><td class=\"tn\">Bone (aşpaz papağı)</td><td class=\"tm\">Nonwoven</td><td class=\"tm\">18 / 21 düym · N100</td></tr>\n        <tr><td class=\"tn\">Chef Hat — Şef papağı</td><td class=\"tm\">Tekstil</td><td class=\"tm\">Tək ölçü</td></tr>\n      </tbody>\n    </table>\n  </div>\n</section>\n\n<!-- HOUSEKEEPING -->\n<section class=\"sec\" id=\"housekeeping\">\n  <div class=\"sec-top rv\">\n    <div>\n      <div style=\"margin-bottom:14px\"><span class=\"eyebrow\" style=\"display:inline-flex;margin:0\">06 / Housekeeping</span> <span class=\"tag\">13 Məhsul · 7 Alt Kateqoriya</span></div>\n      <h2 class=\"h2\">Housekeeping <b>Alətləri</b></h2>\n    </div>\n    <p class=\"sec-desc\">Mikrofiber, mop sistemləri, CEYMOP professional seriyası, teleskop saplar, süpürgələr, təmizlik arabaları.</p>\n  </div>\n  <div class=\"pg rv\">\n<div class=\"pc\"><img class=\"pc-img\" width=\"600\" height=\"152\" src=\"https://images.unsplash.com/photo-1563453392212-326f5e854473?w=600&q=75\" alt=\"Rəngli mikrofiber təmizlik parçaları\" loading=\"lazy\" onerror=\"this.style.display='none'\"><div class=\"pc-body\"><div class=\"pc-name\">Mikrofiber Parça — Color-Coded</div><div class=\"pc-hr\"></div><ul class=\"pc-ul\"><li>300 – 350 GSM</li><li>Rəng kodlaşdırılmış zona sistemi</li><li>Paket / Qutu formatı</li></ul><div class=\"pc-foot\"><span class=\"pc-pkg\">📦 Paket / Qutu</span><span class=\"pc-del\">5–7 gün</span></div></div></div>\n<div class=\"pc\"><img class=\"pc-img\" width=\"600\" height=\"152\" src=\"https://images.unsplash.com/photo-1527515637462-cff94eecc1ac?w=600&q=75\" alt=\"Otel lobisində yaş mop ilə döşəmə təmizliyi\" loading=\"lazy\" onerror=\"this.style.display='none'\"><div class=\"pc-body\"><div class=\"pc-name\">Yaş Mop — Replaceable Head</div><div class=\"pc-hr\"></div><ul class=\"pc-ul\"><li>Cotton / polyester strands</li><li>Dəyişdirilə bilən baş</li><li>1 ədəd / Qutu</li></ul><div class=\"pc-foot\"><span class=\"pc-pkg\">📦 Ədəd / Qutu</span><span class=\"pc-del\">5–7 gün</span></div></div></div>\n<div class=\"pc\"><img class=\"pc-img\" width=\"600\" height=\"152\" src=\"https://images.unsplash.com/photo-1558317374-067fb5f30001?w=600&q=75\" alt=\"Professional mop ped — rəngli təmizlik pedləri\" loading=\"lazy\" onerror=\"this.style.display='none'\"><div class=\"pc-body\"><div class=\"pc-name\">CEYMOP Professional Ped</div><div class=\"pc-hr\"></div><ul class=\"pc-ul\"><li>Ağ / Qırmızı / Qara</li><li>50 / 60 cm mop aparatı</li><li>Makaron 40 / 50 / 60 cm</li></ul></div></div>\n<div class=\"pc\"><img class=\"pc-img\" width=\"600\" height=\"152\" src=\"https://images.unsplash.com/photo-1558317374-067fb5f30001?w=600&q=75\" alt=\"Metal teleskopik sap\" loading=\"lazy\" onerror=\"this.style.display='none'\"><div class=\"pc-body\"><div class=\"pc-name\">Metal Teleskop Sap</div><div class=\"pc-hr\"></div><ul class=\"pc-ul\"><li>2m / 3m / 4m / 4.5m</li><li>130 cm vidalı saplar</li></ul></div></div>\n<div class=\"pc\"><img class=\"pc-img\" width=\"600\" height=\"152\" src=\"https://images.unsplash.com/photo-1528740096961-3798add7e4f3?w=600&q=75\" alt=\"Süpürgə və tualet fırçası — təmizlik alətləri\" loading=\"lazy\" onerror=\"this.style.display='none'\"><div class=\"pc-body\"><div class=\"pc-name\">Süpürgə &amp; Tualet Fırçası</div><div class=\"pc-hr\"></div><ul class=\"pc-ul\"><li>Yumşaq sintetik tüklər</li><li>Krom klozet fırçası</li></ul></div></div>\n<div class=\"pc\"><img class=\"pc-img\" width=\"600\" height=\"152\" src=\"https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=600&q=75\" alt=\"Cam kazıma aparatı — professional şüşə təmizliyi\" loading=\"lazy\" onerror=\"this.style.display='none'\"><div class=\"pc-body\"><div class=\"pc-name\">Cam &amp; Yer Kazıma Aparatı</div><div class=\"pc-hr\"></div><ul class=\"pc-ul\"><li>Cam kazıma jilet + aparatı</li><li>Plastik/metal yer kazıma</li></ul></div></div>\n  </div>\n</section>\n\n<!-- HOVUZ -->\n<section class=\"sec\" id=\"hovuz\" style=\"background:var(--bg2)\">\n  <div class=\"sec-top rv\">\n    <div>\n      <div style=\"margin-bottom:14px\"><span class=\"eyebrow\" style=\"display:inline-flex;margin:0\">07 / Hovuz</span> <span class=\"tag\">8 Məhsul · 1 Alt Kateqoriya</span></div>\n      <h2 class=\"h2\">Hovuz &amp; <b>SPA</b> Kimyəvi</h2>\n    </div>\n    <p class=\"sec-desc\">Xlor qranulat, OXY xlorsuz dezenfektan, pH tənzimləyici, algisid, flokulyant, hovuz parladıcı. SPA və uşaq hovuzu üçün xüsusi formulalar.</p>\n  </div>\n  <div class=\"pg pg3 rv\">\n<div class=\"pc\"><img class=\"pc-img\" width=\"600\" height=\"152\" src=\"https://images.unsplash.com/photo-1509114397022-ed747cca3f65?w=600&q=75\" alt=\"Hovuz xlor qranulları — kimyəvi su təmizləmə\" loading=\"lazy\" onerror=\"this.style.display='none'\"><div class=\"pc-body\"><div class=\"pc-name\">Qranul Xlor 56% &amp; 90%</div><div class=\"pc-hr\"></div><ul class=\"pc-ul\"><li>Trichloroisocyanuric acid</li><li>56% orta / 90% yüksək güc</li><li>Maye xlor 15% alternativ var</li></ul><div class=\"pc-foot\"><span class=\"pc-pkg\">📦 1 / 5 / 25 kg</span><span class=\"pc-del\">5–7 gün</span></div></div></div>\n<div class=\"pc\"><img class=\"pc-img\" width=\"600\" height=\"152\" src=\"https://images.unsplash.com/photo-1576013551627-0cc20b96c2a7?w=600&q=75\" alt=\"Lüks otel SPA — təmiz mavi hovuz\" loading=\"lazy\" onerror=\"this.style.display='none'\"><div class=\"pc-body\"><div class=\"pc-name\">OXY POOL — Xlorsuz Dezenfektan</div><div class=\"pc-hr\"></div><ul class=\"pc-ul\"><li>Aktiv oksigen formulası</li><li>SPA &amp; uşaq hovuzu üçün ideal</li><li>Dəri dostu — az qoxu</li></ul><div class=\"pc-foot\"><span class=\"pc-pkg\">📦 5 / 20 kg</span><span class=\"pc-del\">5–7 gün</span></div></div></div>\n<div class=\"pc\"><img class=\"pc-img\" width=\"600\" height=\"152\" src=\"https://images.unsplash.com/photo-1513694203232-719a280e022f?w=600&q=75\" alt=\"Hovuz suyu pH kimyəvi test və tənzimləmə\" loading=\"lazy\" onerror=\"this.style.display='none'\"><div class=\"pc-body\"><div class=\"pc-name\">pH Düşürücü · Algisid · Parladıcı</div><div class=\"pc-hr\"></div><ul class=\"pc-ul\"><li>pH 7.2 – 7.6 ideal aralıq</li><li>Yosun önləyici (algisid)</li><li>Maye çöktürücü (flokulyant)</li><li>Hovuz parladıcı — şəffaflıq</li></ul><div class=\"pc-foot\"><span class=\"pc-pkg\">📦 Toz &amp; Maye</span><span class=\"pc-del\">5–7 gün</span></div></div></div>\n  </div>\n  <div class=\"note rv\"><p><strong>Su keyfiyyəti standartları:</strong> pH 7.2–7.6 · Free chlorine 0.5–1.5 mg/L · Gündə 2 dəfə test tövsiyə olunur. MI CLEAN GROUP hovuz su analizi xidməti mövcuddur.</p></div>\n</section>","size":12120}