{"embedId":"090b97bc-4422-44a8-9ebb-3cf6f8a71622","html":"<script>// ── Mobile hamburger toggle ─────────────────────────────────────────────────\nfunction toggleNav(){var b=document.getElementById('n-hamburger'),l=document.getElementById('n-links');b.classList.toggle('active');l.classList.toggle('open');b.setAttribute('aria-expanded',l.classList.contains('open'));}\ndocument.querySelectorAll('#n-links a').forEach(function(a){a.addEventListener('click',function(){var b=document.getElementById('n-hamburger'),l=document.getElementById('n-links');b.classList.remove('active');l.classList.remove('open');b.setAttribute('aria-expanded','false');});});\n// ── Dynamic footer year ──────────────────────────────────────────────────────\nvar fyEl = document.getElementById('footer-year');\nif (fyEl) fyEl.textContent = new Date().getFullYear();\n\n// ── Count-up animation for stats ─────────────────────────────────────────────\n(function() {\n  var statsEl = document.querySelector('.stats');\n  if (!statsEl) return;\n  var nums = statsEl.querySelectorAll('.st-n');\n  var animated = false;\n  var so = new IntersectionObserver(function(entries) {\n    if (entries[0].isIntersecting && !animated) {\n      animated = true;\n      nums.forEach(function(n) {\n        var target = parseInt(n.textContent);\n        if (isNaN(target)) return;\n        var start = 0;\n        var duration = 1500;\n        var startTime = null;\n        function step(ts) {\n          if (!startTime) startTime = ts;\n          var progress = Math.min((ts - startTime) / duration, 1);\n          var eased = 1 - Math.pow(1 - progress, 3);\n          n.textContent = Math.round(start + (target - start) * eased);\n          if (progress < 1) requestAnimationFrame(step);\n          else n.textContent = target;\n        }\n        n.textContent = '0';\n        requestAnimationFrame(step);\n      });\n      so.unobserve(statsEl);\n    }\n  }, {threshold: 0.5});\n  so.observe(statsEl);\n})();\n\n// ── Parallax effect for cover image ──────────────────────────────────────────\n(function() {\n  var covImg = document.querySelector('.cov-img');\n  if (!covImg) return;\n  window.addEventListener('scroll', function() {\n    var s = window.scrollY;\n    if (s < window.innerHeight * 1.5) {\n      covImg.style.transform = 'translateY(' + (s * 0.15) + 'px)';\n    }\n  }, {passive: true});\n})();\n\n// ── Nav scroll effect ────────────────────────────────────────────────────────\nvar nav = document.getElementById('nav');\nvar _scrollProg = document.getElementById('scroll-progress');\nvar _backTop = document.getElementById('back-top');\nwindow.addEventListener('scroll', function() {\n  var s = window.scrollY;\n  nav.style.background = s > 60 ? 'rgba(255,255,255,.99)' : 'rgba(255,255,255,.97)';\n  var docH = document.documentElement.scrollHeight - window.innerHeight;\n  _scrollProg.style.width = (docH > 0 ? (s / docH * 100) : 0) + '%';\n  _backTop.classList.toggle('show', s > 300);\n}, { passive: true });\n\nfunction goId(id) { var el = document.getElementById(id); if (el) el.scrollIntoView({ behavior: 'smooth' }); }\n\n// ── Scroll-reveal animations ─────────────────────────────────────────────────\n// Use rootMargin so elements trigger slightly before entering viewport\nvar rvo = new IntersectionObserver(function(entries) {\n  entries.forEach(function(x) {\n    if (x.isIntersecting) { x.target.classList.add('in'); rvo.unobserve(x.target); }\n  });\n}, { threshold: 0.04, rootMargin: '0px 0px 60px 0px' });\ndocument.querySelectorAll('.rv').forEach(function(el) { rvo.observe(el); });\n\n// Staggered fade-in for cards/items — fallback makes everything visible after 2s\nvar co = new IntersectionObserver(function(entries) {\n  entries.forEach(function(x) {\n    if (x.isIntersecting) {\n      x.target.style.opacity = '1';\n      x.target.style.transform = 'none';\n      co.unobserve(x.target);\n    }\n  });\n}, { threshold: 0.03, rootMargin: '0px 0px 80px 0px' });\n\ndocument.querySelectorAll('.cc,.pc,.svc,.why,.step').forEach(function(el, i) {\n  el.style.opacity = '0';\n  el.style.transform = 'translateY(14px)';\n  el.style.transition = 'opacity .5s ease ' + (i % 8 * 0.06) + 's,transform .5s ease ' + (i % 8 * 0.06) + 's,background .25s';\n  co.observe(el);\n});\n// Safety fallback: force-show everything after 2.5s in case observer never fires\nsetTimeout(function() {\n  document.querySelectorAll('.cc,.pc,.svc,.why,.step,.rv').forEach(function(el) {\n    el.style.opacity = '1';\n    el.style.transform = 'none';\n    el.classList.add('in');\n  });\n}, 2500);\n\n// ── Toast notifications ──────────────────────────────────────────────────────\nfunction toast(msg, tp) {\n  var c = document.getElementById('toast-container');\n  var t = document.createElement('div');\n  t.className = 'toast ' + (tp || '');\n  t.innerHTML = '<span>' + msg + '</span><span class=\"toast-x\" onclick=\"this.parentElement.remove()\">&#x2715;</span>';\n  c.appendChild(t);\n  setTimeout(function() { if (t.parentElement) t.remove(); }, 5000);\n}\n\n// ── Modal helpers ────────────────────────────────────────────────────────────\nvar _prevFocus = null;\nfunction openM(n) {\n  _prevFocus = document.activeElement;\n  var overlay = document.getElementById('modal-' + n);\n  overlay.classList.add('open');\n  overlay.setAttribute('aria-hidden', 'false');\n  document.body.style.overflow = 'hidden';\n  if (n === 'quote') populateQuoteBasket();\n  // Move focus to first focusable element inside modal\n  setTimeout(function() {\n    var first = overlay.querySelector('input,select,textarea,button,[tabindex]:not([tabindex=\"-1\"])');\n    if (first) first.focus();\n  }, 50);\n}\nfunction closeM(n) {\n  var overlay = document.getElementById('modal-' + n);\n  overlay.classList.remove('open');\n  overlay.setAttribute('aria-hidden', 'true');\n  document.body.style.overflow = '';\n  if (_prevFocus) { _prevFocus.focus(); _prevFocus = null; }\n}\ndocument.querySelectorAll('.modal-overlay').forEach(function(m) {\n  m.setAttribute('role', 'dialog');\n  m.setAttribute('aria-modal', 'true');\n  m.setAttribute('aria-hidden', 'true');\n  m.addEventListener('click', function(e) { if (e.target === m) { m.classList.remove('open'); m.setAttribute('aria-hidden','true'); document.body.style.overflow = ''; } });\n  // Focus trap: keep Tab/Shift+Tab inside modal\n  m.addEventListener('keydown', function(e) {\n    if (!m.classList.contains('open')) return;\n    if (e.key !== 'Tab') return;\n    var focusable = Array.from(m.querySelectorAll('input,select,textarea,button,a[href],[tabindex]:not([tabindex=\"-1\"])')).filter(function(el) { return !el.disabled; });\n    if (!focusable.length) return;\n    var first = focusable[0], last = focusable[focusable.length - 1];\n    if (e.shiftKey) { if (document.activeElement === first) { e.preventDefault(); last.focus(); } }\n    else { if (document.activeElement === last) { e.preventDefault(); first.focus(); } }\n  });\n});\ndocument.addEventListener('keydown', function(e) {\n  var tag = document.activeElement ? document.activeElement.tagName : '';\n  var inInput = (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT');\n\n  // Esc — close any open modal\n  if (e.key === 'Escape') {\n    document.querySelectorAll('.modal-overlay.open').forEach(function(m) {\n      closeM(m.id.replace('modal-', ''));\n    });\n    return;\n  }\n\n  // / — focus search (only when not typing in a field)\n  if (e.key === '/' && !inInput) {\n    e.preventDefault();\n    var si = document.getElementById('sinput');\n    si.focus(); si.select();\n    return;\n  }\n\n  // Arrow keys — navigate cards in detail modal\n  if ((e.key === 'ArrowRight' || e.key === 'ArrowLeft') && document.getElementById('modal-detail').classList.contains('open')) {\n    e.preventDefault();\n    var cards = Array.from(document.querySelectorAll('.pc'));\n    var idx = _currentPC ? cards.indexOf(_currentPC) : -1;\n    if (idx === -1) return;\n    var next = e.key === 'ArrowRight' ? cards[idx + 1] : cards[idx - 1];\n    if (next) openDetail(next);\n    return;\n  }\n});\n\n// ── Product search ───────────────────────────────────────────────────────────\nvar sdata = null, cfilter = 'all', stimer = null;\n// Static product data (embedded at build time)\nsdata=[{\"name\":\"Ümumi Səth Təmizləyici — Konsentrat\",\"id\":\"KTÜT-001\",\"category\":\"kimyevi\",\"haccp\":false},{\"name\":\"Döşəmə Təmizləyici — Neytral pH\",\"id\":\"KTDT-002\",\"category\":\"kimyevi\",\"haccp\":false},{\"name\":\"Şüşə & Güzgü Təmizləyici\",\"id\":\"KTŞT-003 / KTAT-004\",\"category\":\"kimyevi\",\"haccp\":false},{\"name\":\"Alkoqollu Dezinfektan Spray\",\"id\":\"KTD-005 / Spray\",\"category\":\"kimyevi\",\"haccp\":false},{\"name\":\"Spirt Əsaslı Əl Dezinfektantı 95%\",\"id\":\"KTD-005 / Əl\",\"category\":\"kimyevi\",\"haccp\":false},{\"name\":\"QAC Əsaslı Dezinfektan Konsentrat\",\"id\":\"KTD-005 / QAC\",\"category\":\"kimyevi\",\"haccp\":false},{\"name\":\"Tualet Təmizləyici — Turş Əsaslı ECO\",\"id\":\"KTSQ-007\",\"category\":\"kimyevi\",\"haccp\":false},{\"name\":\"Food-Grade Sanitizer — No-Rinse HACCP\",\"id\":\"KTQT-006\",\"category\":\"kimyevi\",\"haccp\":true},{\"name\":\"Dezinfeksiyaedici Banyo Təmizləyici RTU\",\"id\":\"KTSQ-007 / RTU\",\"category\":\"kimyevi\",\"haccp\":false},{\"name\":\"Sənaye Yuyucu Toz — Yüksək Aktivlik\",\"id\":\"CAM-001 / Toz\",\"category\":\"camasirxana\",\"haccp\":false},{\"name\":\"Sənaye Yuyucu Maye — Low-Temp\",\"id\":\"CAM-002 / Maye\",\"category\":\"camasirxana\",\"haccp\":false},{\"name\":\"Tekstil Yumşaldıcı Konsentrat\",\"id\":\"CAM-003 / Yumşaldıcı\",\"category\":\"camasirxana\",\"haccp\":false},{\"name\":\"6 Çıxışlı Venturi Pompası\",\"id\":\"\",\"category\":\"camasirxana\",\"haccp\":false},{\"name\":\"6 Çıxışlı Peristalgik Pompa\",\"id\":\"\",\"category\":\"camasirxana\",\"haccp\":false},{\"name\":\"4 / 8 Pozisiyalı Qarışdırıcı\",\"id\":\"\",\"category\":\"camasirxana\",\"haccp\":false},{\"name\":\"Mobil Köpük Aparatı\",\"id\":\"\",\"category\":\"camasirxana\",\"haccp\":false},{\"name\":\"Qabyuyan Maşın Pompası\",\"id\":\"\",\"category\":\"camasirxana\",\"haccp\":false},{\"name\":\"Soba / Gril Təmizləyici — Güclü\",\"id\":\"MTB-001\",\"category\":\"metbex\",\"haccp\":false},{\"name\":\"Mətbəx Yağtəmizləyici Konsentrat\",\"id\":\"MTB-002\",\"category\":\"metbex\",\"haccp\":false},{\"name\":\"Paslanmaz Polad Təmizləyici\",\"id\":\"MTB-003\",\"category\":\"metbex\",\"haccp\":false},{\"name\":\"Manuel Qab Yuyucu Maye\",\"id\":\"MTB-004\",\"category\":\"metbex\",\"haccp\":false},{\"name\":\"Food-Grade Sanitizer RTU\",\"id\":\"MTB-005\",\"category\":\"metbex\",\"haccp\":true},{\"name\":\"Avtomatik Qabyuyan Deterjanı\",\"id\":\"MTB-006\",\"category\":\"metbex\",\"haccp\":false},{\"name\":\"Alüminium Qablar + Qapaq\",\"id\":\"\",\"category\":\"istehlak\",\"haccp\":false},{\"name\":\"Karton Stəkan — 8 OZ / 12 OZ\",\"id\":\"\",\"category\":\"istehlak\",\"haccp\":false},{\"name\":\"Bio Çəngəl / Qaşıq / Bıçaq Seti\",\"id\":\"\",\"category\":\"istehlak\",\"haccp\":false},{\"name\":\"Pizza / Pide Qutuları\",\"id\":\"\",\"category\":\"istehlak\",\"haccp\":false},{\"name\":\"Mikrofiber Parça — Color-Coded\",\"id\":\"\",\"category\":\"housekeeping\",\"haccp\":false},{\"name\":\"Yaş Mop — Replaceable Head\",\"id\":\"\",\"category\":\"housekeeping\",\"haccp\":false},{\"name\":\"CEYMOP Professional Ped\",\"id\":\"\",\"category\":\"housekeeping\",\"haccp\":false},{\"name\":\"Metal Teleskop Sap\",\"id\":\"\",\"category\":\"housekeeping\",\"haccp\":false},{\"name\":\"Süpürgə & Tualet Fırçası\",\"id\":\"\",\"category\":\"housekeeping\",\"haccp\":false},{\"name\":\"Cam & Yer Kazıma Aparatı\",\"id\":\"\",\"category\":\"housekeeping\",\"haccp\":false},{\"name\":\"Qranul Xlor 56% & 90%\",\"id\":\"\",\"category\":\"hovuz\",\"haccp\":false},{\"name\":\"OXY POOL — Xlorsuz Dezinfektan\",\"id\":\"\",\"category\":\"hovuz\",\"haccp\":false},{\"name\":\"pH Düşürücü · Algisid · Parladıcı\",\"id\":\"\",\"category\":\"hovuz\",\"haccp\":false}];\n\nfunction setF(c, btn) {\n  cfilter = c;\n  document.querySelectorAll('.fbtn').forEach(function(b) { b.classList.remove('active'); });\n  btn.classList.add('active');\n  var q = document.getElementById('sinput').value.trim();\n  if (q) doS(q);\n  var pp = document.getElementById('sub-pills');\n  if (c === 'all') { pp.className = ''; pp.innerHTML = ''; }\n  else {\n    var sc = SUBCATS[c] || [];\n    if (sc.length) {\n      pp.className = 'open';\n      pp.innerHTML = sc.map(function(s) {\n        return '<button class=\"spill\" onclick=\"clickPill(\\'' + s.replace(/'/g,\"\\\\'\") + '\\',\\'' + c + '\\')\">' + s + '</button>';\n      }).join('');\n    } else { pp.className = ''; pp.innerHTML = ''; }\n  }\n}\ndocument.getElementById('sinput').addEventListener('input', function() {\n  clearTimeout(stimer);\n  var q = this.value.trim();\n  stimer = setTimeout(function() { doS(q); }, 200);\n});\ndocument.getElementById('sinput').addEventListener('keydown', function(e) { if (e.key === 'Escape') { this.value = ''; hideS(); } });\ndocument.addEventListener('click', function(e) { if (!e.target.closest('#sbar')) hideS(); });</script>","size":12363}