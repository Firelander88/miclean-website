">5★</div><div class=\"st-l\">Standart</div></div>\n    </div>\n    <a href=\"#overview\" class=\"cov-link\">Kataloqa bax →</a>\n  </div>\n  <div class=\"cov-r\">\n    <img class=\"cov-img\" src=\"https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=1200&q=80&fm=webp\" alt=\"Lüks otel otağı\" fetchpriority=\"high\" onerror=\"this.style.display='none'\">\n    <div class=\"cov-badge\"><b>15</b><span>Xidmət<br>növü</span></div>\n  </div>\n</section>\n\n<!-- OVERVIEW -->\n<section class=\"sec sec-cream\" id=\"overview\">\n  <div class=\"sec-top rv\">\n    <div>\n      <div class=\"eyebrow\" style=\"color:var(--gold)\">Məhsul xəritəsi</div>\n      <h2 class=\"h2\" style=\"color:var(--white)\">7 Kateqoriya,<br><b>109 Alt Bölmə</b></h2>\n    </div>\n    <p class=\"sec-desc-dark\">Kimyəvi təmizlikdən premium amenity xəttinə qədər otelin hər bir ehtiyacı üçün sertifikatlı məhsullar.</p>\n  </div>\n  <div class=\"cat-grid rv\">\n    <div class=\"cc\" tabindex=\"0\" role=\"button\" onkeydown=\"if(event.key==='Enter'||event.key===' '){event.preventDefault();this.click()}\" onclick=\"goId('kimyevi')\">\n      <img class=\"cc-img\" width=\"600\" height=\"690\" src=\"https://images.unsplash.com/photo-1585421514738-01798e348b17?w=600&q=75\" alt=\"Kimyəvi Təmizlik Vasitələri\" loading=\"lazy\" onerror=\"this.style.opacity='0'\">\n      <div class=\"cc-body\"><div class=\"cc-n\">01 / 07</div><div class=\"cc-name\">Kimyəvi Təmizlik Vasitələri</div><div class=\"cc-meta\">127 məhsul · 25 alt bölmə</div></div>\n      <div class=\"cc-bar\"></div></div>\n    <div class=\"cc\" tabindex=\"0\" role=\"button\" onkeydown=\"if(event.key==='Enter'||event.key===' '){event.preventDefault();this.click()}\" onclick=\"goId('camasirxana')\">\n      <img class=\"cc-img\" width=\"600\" height=\"690\" src=\"https://images.unsplash.com/photo-1626806819282-2c1dc01a5e0c?w=600&q=75\" alt=\"Camaşırxana Məhsulları\" loading=\"lazy\" onerror=\"this.style.opacity='0'\">\n      <div class=\"cc-body\"><di