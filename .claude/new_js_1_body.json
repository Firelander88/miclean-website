{"customEmbed": {"name": "MI CLEAN JS 1", "enabled": true, "loadOnce": false, "position": "BODY_END", "embedData": {"category": "ESSENTIAL", "html": "<script>// \u2500\u2500 Dynamic footer year \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nvar fyEl = document.getElementById('footer-year');\nif (fyEl) fyEl.textContent = new Date().getFullYear();\n\n// \u2500\u2500 Count-up animation for stats \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n(function() {\n  var statsEl = document.querySelector('.stats');\n  if (!statsEl) return;\n  var nums = statsEl.querySelectorAll('.st-n');\n  var animated = false;\n  var so = new IntersectionObserver(function(entries) {\n    if (entries[0].isIntersecting && !animated) {\n      animated = true;\n      nums.forEach(function(n) {\n        var target = parseInt(n.textContent);\n        if (isNaN(target)) return;\n        var start = 0;\n        var duration = 1500;\n        var startTime = null;\n        function step(ts) {\n          if (!startTime) startTime = ts;\n          var progress = Math.min((ts - startTime) / duration, 1);\n          var eased = 1 - Math.pow(1 - progress, 3);\n          n.textContent = Math.round(start + (target - start) * eased);\n          if (progress < 1) requestAnimationFrame(step);\n          else n.textContent = target;\n        }\n        n.textContent = '0';\n        requestAnimationFrame(step);\n      });\n      so.unobserve(statsEl);\n    }\n  }, {threshold: 0.5});\n  so.observe(statsEl);\n})();\n\n// \u2500\u2500 Parallax effect for cover image \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n(function() {\n  var covImg = document.querySelector('.cov-img');\n  if (!covImg) return;\n  window.addEventListener('scroll', function() {\n    var s = window.scrollY;\n    if (s < window.innerHeight * 1.5) {\n      covImg.style.transform = 'translateY(' + (s * 0.15) + 'px)';\n    }\n  }, {passive: true});\n})();\n\n// \u2500\u2500 Nav scroll effect \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nvar nav = document.getElementById('nav');\nvar _scrollProg = document.getElementById('scroll-progress');\nvar _backTop = document.getElementById('back-top');\nwindow.addEventListener('scroll', function() {\n  var s = window.scrollY;\n  nav.style.background = s > 60 ? 'rgba(7,17,28,.99)' : 'rgba(7,17,28,.96)';\n  var docH = document.documentElement.scrollHeight - window.innerHeight;\n  _scrollProg.style.width = (docH > 0 ? (s / docH * 100) : 0) + '%';\n  _backTop.classList.toggle('show', s > 300);\n}, { passive: true });\n\nfunction goId(id) { var el = document.getElementById(id); if (el) el.scrollIntoView({ behavior: 'smooth' }); }\n\n// \u2500\u2500 Scroll-reveal animations \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n// Use rootMargin so elements trigger slightly before entering viewport\nvar rvo = new IntersectionObserver(function(entries) {\n  entries.forEach(function(x) {\n    if (x.isIntersecting) { x.target.classList.add('in'); rvo.unobserve(x.target); }\n  });\n}, { threshold: 0.04, rootMargin: '0px 0px 60px 0px' });\ndocument.querySelectorAll('.rv').forEach(function(el) { rvo.observe(el); });\n\n// Staggered fade-in for cards/items \u2014 fallback makes everything visible after 2s\nvar co = new IntersectionObserver(function(entries) {\n  entries.forEach(function(x) {\n    if (x.isIntersecting) {\n      x.target.style.opacity = '1';\n      x.target.style.transform = 'none';\n      co.unobserve(x.target);\n    }\n  });\n}, { threshold: 0.03, rootMargin: '0px 0px 80px 0px' });\n\ndocument.querySelectorAll('.cc,.pc,.svc,.why,.step').forEach(function(el, i) {\n  el.style.opacity = '0';\n  el.style.transform = 'translateY(14px)';\n  el.style.transition = 'opacity .5s ease ' + (i % 8 * 0.06) + 's,transform .5s ease ' + (i % 8 * 0.06) + 's,background .25s';\n  co.observe(el);\n});\n// Safety fallback: force-show everything after 2.5s in case observer never fires\nsetTimeout(function() {\n  document.querySelectorAll('.cc,.pc,.svc,.why,.step,.rv').forEach(function(el) {\n    el.style.opacity = '1';\n    el.style.transform = 'none';\n    el.classList.add('in');\n  });\n}, 2500);\n\n// \u2500\u2500 Toast notifications \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nfunction toast(msg, tp) {\n  var c = document.getElementById('toast-container');\n  var t = document.createElement('div');\n  t.className = 'toast ' + (tp || '');\n  t.innerHTML = '<span>' + msg + '</span><span class=\"toast-x\" onclick=\"this.parentElement.remove()\">&#x2715;</span>';\n  c.appendChild(t);\n  setTimeout(function() { if (t.parentElement) t.remove(); }, 5000);\n}\n\n// \u2500\u2500 Modal helpers \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nvar _prevFocus = null;\nfunction openM(n) {\n  _prevFocus = document.activeElement;\n  var overlay = document.getElementById('modal-' + n);\n  overlay.classList.add('open');\n  overlay.setAttribute('aria-hidden', 'false');\n  document.body.style.overflow = 'hidden';\n  if (n === 'quote') populateQuoteBasket();\n  // Move focus to first focusable element inside modal\n  setTimeout(function() {\n    var first = overlay.querySelector('input,select,textarea,button,[tabindex]:not([tabindex=\"-1\"])');\n    if (first) first.focus();\n  }, 50);\n}\nfunction closeM(n) {\n  var overlay = document.getElementById('modal-' + n);\n  overlay.classList.remove('open');\n  overlay.setAttribute('aria-hidden', 'true');\n  document.body.style.overflow = '';\n  if (_prevFocus) { _prevFocus.focus(); _prevFocus = null; }\n}\ndocument.querySelectorAll('.modal-overlay').forEach(function(m) {\n  m.setAttribute('role', 'dialog');\n  m.setAttribute('aria-modal', 'true');\n  m.setAttribute('aria-hidden', 'true');\n  m.addEventListener('click', function(e) { if (e.target === m) { m.classList.remove('open'); m.setAttribute('aria-hidden','true'); document.body.style.overflow = ''; } });\n  // Focus trap: keep Tab/Shift+Tab inside modal\n  m.addEventListener('keydown', function(e) {\n    if (!m.classList.contains('open')) return;\n    if (e.key !== 'Tab') return;\n    var focusable = Array.from(m.querySelectorAll('input,select,textarea,button,a[href],[tabindex]:not([tabindex=\"-1\"])')).filter(function(el) { return !el.disabled; });\n    if (!focusable.length) return;\n    var first = focusable[0], last = focusable[focusable.length - 1];\n    if (e.shiftKey) { if (document.activeElement === first) { e.preventDefault(); last.focus(); } }\n    else { if (document.activeElement === last) { e.preventDefault(); first.focus(); } }\n  });\n});\ndocument.addEventListener('keydown', function(e) {\n  var tag = document.activeElement ? document.activeElement.tagName : '';\n  var inInput = (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT');\n\n  // Esc \u2014 close any open modal\n  if (e.key === 'Escape') {\n    document.querySelectorAll('.modal-overlay.open').forEach(function(m) {\n      closeM(m.id.replace('modal-', ''));\n    });\n    return;\n  }\n\n  // / \u2014 focus search (only when not typing in a field)\n  if (e.key === '/' && !inInput) {\n    e.preventDefault();\n    var si = document.getElementById('sinput');\n    si.focus(); si.select();\n    return;\n  }\n\n  // Arrow keys \u2014 navigate cards in detail modal\n  if ((e.key === 'ArrowRight' || e.key === 'ArrowLeft') && document.getElementById('modal-detail').classList.contains('open')) {\n    e.preventDefault();\n    var cards = Array.from(document.querySelectorAll('.pc'));\n    var idx = _currentPC ? cards.indexOf(_currentPC) : -1;\n    if (idx === -1) return;\n    var next = e.key === 'ArrowRight' ? cards[idx + 1] : cards[idx - 1];\n    if (next) openDetail(next);\n    return;\n  }\n});\n\n// \u2500\u2500 Product search \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nvar sdata = null, cfilter = 'all', stimer = null;\nfetch('/api/products?limit=1000').then(function(r) { return r.json(); }).then(function(d) { sdata = d.products; }).catch(function() {});\n\nfunction setF(c, btn) {\n  cfilter = c;\n  document.querySelectorAll('.fbtn').forEach(function(b) { b.classList.remove('active'); });\n  btn.classList.add('active');\n  var q = document.getElementById('sinput').value.trim();\n  if (q) doS(q);\n  var pp = document.getElementById('sub-pills');\n  if (c === 'all') { pp.className = ''; pp.innerHTML = ''; }\n  else {\n    var sc = SUBCATS[c] || [];\n    if (sc.length) {\n      pp.className = 'open';\n      pp.innerHTML = sc.map(function(s) {\n        return '<button class=\"spill\" onclick=\"clickPill(\\'' + s.replace(/'/g,\"\\\\'\") + '\\',\\'' + c + '\\')\">' + s + '</button>';\n      }).join('');\n    } else { pp.className = ''; pp.innerHTML = ''; }\n  }\n}\ndocument.getElementById('sinput').addEventListener('input', function() {\n  clearTimeout(stimer);\n  var q = this.value.trim();\n  stimer = setTimeout(function() { doS(q); }, 200);\n});\ndocument.getElementById('sinput').addEventListener('keydown', function(e) { if (e.key === 'Escape') { this.value = ''; hideS(); } });\ndocument.addEventListener('click', function(e) { if (!e.target.closest('#sbar')) hideS(); });\n\nvar CATS = { kimyevi: 'Kimy\u0259vi', camasirxana: 'Cama\u015f\u0131rxana', metbex: 'M\u0259tb\u0259x', amenity: 'Amenity', istehlak: '\u0130stehlak', housekeeping: 'Housekeeping', hovuz: 'Hovuz & SPA' };\nfunction doS(q) {\n  var r = document.getElementById('sres');\n  if (!q) { hideS(); return; }\n  if (!sdata) {\n    r.style.display = 'block';\n    r.innerHTML = [1,2,3].map(function() {\n      return '<div class=\"sk-item\"><div class=\"sk-thumb\"></div><div class=\"sk-lines\"><div class=\"sk-l\" style=\"width:68%\"></div><div class=\"sk-l\" style=\"width:40%\"></div></div></div>';\n    }).join('');\n    document.getElementById('sinput').setAttribute('aria-expanded','true');\n    return;\n  }\n  var ql = q.toLowerCase();\n  var f = sdata.filter(function(p) {\n    var m = (cfilter === 'all' || p.category === cfilter);\n    return m && (p.name.toLowerCase().indexOf(ql) > -1 || (p.id && p.id.toLowerCase().indexOf(ql) > -1) || (p.formula && p.formula.toLowerCase().indexOf(ql) > -1));\n  });\n  var sv = document.getElementById('ssort').value;\n  if (sv === 'az') f.sort(function(a,b) { return a.name.localeCompare(b.name); });\n  else if (sv === 'haccp') f.sort(function(a,b) { return (b.haccp ? 1:0) - (a.haccp ? 1:0); });\n  else if (sv === 'eco') f.sort(function(a,b) {\n    var ae = a.name.toLowerCase().indexOf('eco') > -1 ? 1:0;\n    var be = b.name.toLowerCase().indexOf('eco') > -1 ? 1:0;\n    return be - ae;\n  });\n  f = f.slice(0, 8);\n  if (!f.length) {\n    var qs = q.replace(/</g,'&lt;').replace(/>/g,'&gt;');\n    r.style.display = 'block';\n    r.innerHTML = '<div class=\"sri-empty\"><svg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" fill=\"none\"><circle cx=\"18\" cy=\"18\" r=\"10\" stroke=\"#7A94A8\" stroke-width=\"1.5\"/><path d=\"M26 26l6 6\" stroke=\"#7A94A8\" stroke-width=\"1.5\" stroke-linecap=\"round\"/><path d=\"M13 18h10\" stroke=\"#C9A96E\" stroke-width=\"1.5\" stroke-linecap=\"round\" opacity=\".5\"/></svg><p>\u00ab<span>' + qs + '</span>\u00bb \u00fczr\u0259 n\u0259tic\u0259 tap\u0131lmad\u0131.<br>Axtar\u0131\u015f ifad\u0259sini d\u0259yi\u015fin.</p></div>';\n    document.getElementById('sinput').setAttribute('aria-expanded','true');\n    return;\n  }\n  var h = f.map(function(p) {\n    var ig = p.image ? ('<img class=\"sri-img\" src=\"'+p.image+'\" alt=\"'+(p.name||'M\u0259hsul').replace(/\"/g,'&quot;')+'\" onerror=\"this.style.display=\\'none\\'\">') : '';\n    var hb = p.haccp ? ' <span class=\"bdg bdg-haccp\" style=\"font-size:7px;padding:2px 6px;vertical-align:middle\">HACCP</span>' : '';\n    return '<div class=\"sri\" onclick=\"goS(\\''+p.category+'\\')\">'+ig+'<div><div class=\"sri-name\">'+p.name+hb+'</div><div class=\"sri-cat\">'+(CATS[p.category]||p.category)+'</div>'+(p.id?'<div class=\"sri-id\">'+p.id+'</div>':'')+' </div></div>';\n  }).join('');\n  r.style.display = 'block';\n  r.innerHTML = h;\n  document.getElementById('sinput').setAttribute('aria-expanded','true');\n}\nfunction goS(cat) { hideS(); document.getElementById('sinput').value = ''; var el = document.getElementById(cat); if (el) el.scrollIntoView({ behavior: 'smooth' }); }\nfunction hideS() {\n  var sr = document.getElementById('sres');\n  sr.style.display = 'none';\n  document.getElementById('sinput').setAttribute('aria-expanded', 'false');\n}\n\n// \u2500\u2500 Contact form \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nfunction subC() {\n  var form = document.getElementById('cform');\n  var btn = document.getElementById('cbtn');\n  if (!form.name.value || !form.email.value || !form.hotel.value || !form.message.value) {\n    toast('Z\u0259ruri sah\u0259l\u0259ri doldurun.', 'error'); return;\n  }\n  btn.disabled = true;\n  btn.textContent = 'G\u00f6nd\u0259rilir...';\n  fetch('/api/contact', {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ name: form.name.value, email: form.email.value, phone: form.phone.value, hotel: form.hotel.value, message: form.message.value })\n  }).then(function(r) { return r.json(); }).then(function(d) {\n    if (d.success) {\n      toast('\u2713 Mesaj\u0131n\u0131z g\u00f6nd\u0259rildi! Tezlikl\u0259 \u0259laq\u0259 saxlayaca\u011f\u0131q.', 'success');\n      form.reset();\n    } else {\n      toast('X\u0259ta: ' + (d.message || 'Yenid\u0259n c\u0259hd edin.'), 'error');\n    }\n  }).catch(function() {\n    toast('X\u0259ta. Yenid\u0259n c\u0259hd edin.', 'error');\n  }).finally(function() {\n    btn.disabled = false;\n    btn.textContent = 'G\u00f6nd\u0259r';\n  });\n}\n\n// \u2500\u2500 Quote form \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nfunction subQ() {\n  var form = document.getElementById('qform');\n  var btn = document.getElementById('qbtn');\n  var cats = Array.from(form.querySelectorAll('input[name=\"cats\"]:checked')).map(function(i) { return i.value; });\n  if (!cats.length) { document.getElementById('cerr').style.display = 'block'; return; }\n  document.getElementById('cerr').style.display = 'none';\n  if (!form.name.value || !form.email.value || !form.hotel.value) { toast('Z\u0259ruri sah\u0259l\u0259ri doldurun.', 'error'); return; }\n  btn.disabled = true;\n  btn.classList.add('loading');\n  btn.textContent = 'G\u00f6nd\u0259rilir...';\n  fetch('/api/quotes', {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ name: form.name.value, email: form.email.value, phone: form.phone.value, hotel: form.hotel.value, hotel_stars: form.hotel_stars.value, categories: cats, notes: form.notes.value, pilot: form.querySelector('[name=\"pilot\"]').checked })\n  }).then(function(r) { return r.json(); }).then(function(d) {\n    if (d.success) {\n      closeM('quote');\n      toast('\u2713 Sor\u011funuz q\u0259bul edildi!', 'success');\n      form.reset();\n      document.querySelectorAll('.fcat-item').forEach(function(i) { i.classList.remove('checked'); });\n    } else {\n      toast('X\u0259ta: ' + (d.message || 'Yenid\u0259n c\u0259hd edin.'), 'error');\n    }\n  }).catch(function() {\n    toast('X\u0259ta. Yenid\u0259n c\u0259hd edin.', 'error');\n  }).finally(function() {\n    btn.disabled = false;\n    btn.classList.remove('loading');\n    btn.textContent = 'Sor\u011fu G\u00f6nd\u0259r';\n  });\n}\n</script>"}}}