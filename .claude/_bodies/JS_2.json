{"customEmbed":{"id":"95b059e5-3698-4ad1-be6d-2a5df331296b","revision":"999","embedData":{"category":"ESSENTIAL","html":"<script>\n\nvar CATS = { kimyevi: 'Kimyəvi', camasirxana: 'Camaşırxana', metbex: 'Mətbəx', amenity: 'Amenity', istehlak: 'İstehlak', housekeeping: 'Housekeeping', hovuz: 'Hovuz & SPA' };\nfunction doS(q) {\n  var r = document.getElementById('sres');\n  if (!q) { hideS(); return; }\n  if (!sdata) {\n    r.style.display = 'block';\n    r.innerHTML = [1,2,3].map(function() {\n      return '<div class=\"sk-item\"><div class=\"sk-thumb\"></div><div class=\"sk-lines\"><div class=\"sk-l\" style=\"width:68%\"></div><div class=\"sk-l\" style=\"width:40%\"></div></div></div>';\n    }).join('');\n    document.getElementById('sinput').setAttribute('aria-expanded','true');\n    return;\n  }\n  var ql = q.toLowerCase();\n  var f = sdata.filter(function(p) {\n    var m = (cfilter === 'all' || p.category === cfilter);\n    return m && (p.name.toLowerCase().indexOf(ql) > -1 || (p.id && p.id.toLowerCase().indexOf(ql) > -1) || (p.formula && p.formula.toLowerCase().indexOf(ql) > -1));\n  });\n  var sv = document.getElementById('ssort').value;\n  if (sv === 'az') f.sort(function(a,b) { return a.name.localeCompare(b.name); });\n  else if (sv === 'haccp') f.sort(function(a,b) { return (b.haccp ? 1:0) - (a.haccp ? 1:0); });\n  else if (sv === 'eco') f.sort(function(a,b) {\n    var ae = a.name.toLowerCase().indexOf('eco') > -1 ? 1:0;\n    var be = b.name.toLowerCase().indexOf('eco') > -1 ? 1:0;\n    return be - ae;\n  });\n  f = f.slice(0, 8);\n  if (!f.length) {\n    var qs = q.replace(/</g,'&lt;').replace(/>/g,'&gt;');\n    r.style.display = 'block';\n    r.innerHTML = '<div class=\"sri-empty\"><svg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" fill=\"none\"><circle cx=\"18\" cy=\"18\" r=\"10\" stroke=\"#4A5968\" stroke-width=\"1.5\"/><path d=\"M26 26l6 6\" stroke=\"#4A5968\" stroke-width=\"1.5\" stroke-linecap=\"round\"/><path d=\"M13 18h10\" stroke=\"#A38A1F\" stroke-width=\"1.5\" stroke-linecap=\"round\" opacity=\".5\"/></svg><p>«<span>' + qs + '</span>» üzrə nəticə tapılmadı.<br>Axtarış ifadəsini dəyişin.</p></div>';\n    document.getElementById('sinput').setAttribute('aria-expanded','true');\n    return;\n  }\n  function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');}\n  var h = f.map(function(p) {\n    var nm = esc(p.name||'Məhsul');\n    var ig = p.image ? ('<img class=\"sri-img\" src=\"'+esc(p.image)+'\" alt=\"'+nm+'\" onerror=\"this.style.display=\\'none\\'\">') : '';\n    var hb = p.haccp ? ' <span class=\"bdg bdg-haccp\" style=\"font-size:7px;padding:2px 6px;vertical-align:middle\">HACCP</span>' : '';\n    return '<div class=\"sri\" onclick=\"goS(\\''+esc(p.category)+'\\')\">'+ig+'<div><div class=\"sri-name\">'+nm+hb+'</div><div class=\"sri-cat\">'+esc(CATS[p.category]||p.category)+'</div>'+(p.id?'<div class=\"sri-id\">'+esc(p.id)+'</div>':'')+' </div></div>';\n  }).join('');\n  r.style.display = 'block';\n  r.innerHTML = h;\n  document.getElementById('sinput').setAttribute('aria-expanded','true');\n}\nfunction goS(cat) { hideS(); document.getElementById('sinput').value = ''; var el = document.getElementById(cat); if (el) el.scrollIntoView({ behavior: 'smooth' }); }\nfunction hideS() {\n  var sr = document.getElementById('sres');\n  sr.style.display = 'none';\n  document.getElementById('sinput').setAttribute('aria-expanded', 'false');\n}\n\n// ── Contact form ─────────────────────────────────────────────────────────────\nfunction subC() {\n  var form = document.getElementById('cform');\n  var btn = document.getElementById('cbtn');\n  // Honeypot anti-spam\n  var hp = form.querySelector('[name=\"website\"]');\n  if (hp && hp.value) return;\n  // Validation\n  var errors = [];\n  if (!form.name.value.trim()) errors.push('Ad');\n  if (!form.email.value.trim() || !/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(form.email.value)) errors.push('Düzgün email');\n  if (!form.hotel.value.trim()) errors.push('Otel/Şirkət');\n  if (!form.message.value.trim()) errors.push('Mesaj');\n  if (errors.length) {\n    toast('Zəruri sahələri düzgün doldurun: ' + errors.join(', '), 'error'); return;\n  }\n  btn.disabled = true;\n  btn.textContent = 'Göndərilir...';\n  var subject = encodeURIComponent('Saytdan əlaqə: ' + form.name.value);\n  var body = encodeURIComponent('Ad: ' + form.name.value + '\\nEmail: ' + form.email.value + '\\nTelefon: ' + (form.phone.value || '—') + '\\nOtel/Şirkət: ' + form.hotel.value + '\\n\\nMesaj:\\n' + form.message.value);\n  window.open('mailto:micleangroupmmc@gmail.com?subject=' + subject + '&body=' + body);\n  toast('✓ E-poçt proqramınız açılacaq. Mesajı göndərin.', 'success');\n  form.reset();\n  btn.disabled = false;\n  btn.textContent = 'Göndər';\n}\n\n// ── Quote form ───────────────────────────────────────────────────────────────\nfunction subQ() {\n  var form = document.getElementById('qform');\n  var btn = document.getElementById('qbtn');\n  // Honeypot anti-spam\n  var hp = form.querySelector('[name=\"q_website\"]');\n  if (hp && hp.value) return;\n  var cats = Array.from(form.querySelectorAll('input[name=\"cats\"]:checked')).map(function(i) { return i.value; });\n  if (!cats.length) { document.getElementById('cerr').style.display = 'block'; return; }\n  document.getElementById('cerr').style.display = 'none';\n  // Validation\n  var errors = [];\n  if (!form.name.value.trim()) errors.push('Ad');\n  if (!form.email.value.trim() || !/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(form.email.value)) errors.push('Düzgün email');\n  if (!form.hotel.value.trim()) errors.push('Otel/Şirkət');\n  if (errors.length) { toast('Zəruri sahələri düzgün doldurun: ' + errors.join(', '), 'error'); return; }\n  btn.disabled = true;\n  btn.classList.add('loading');\n  btn.textContent = 'Göndərilir...';\n  var basketItems = quoteBasket || [];\n  var basketText = basketItems.length ? '\\n\\nSeçilmiş məhsullar:\\n' + basketItems.map(function(b) { return '- ' + b.name + ' (' + b.code + ')'; }).join('\\n') : '';\n  var subject = encodeURIComponent('Qiymət Sorğusu: ' + form.hotel.value);\n  var body = encodeURIComponent('Ad: ' + form.name.value + '\\nEmail: ' + form.email.value + '\\nTelefon: ' + (form.phone.value || '—') + '\\nOtel/Şirkət: ' + form.hotel.value + '\\nUlduz: ' + (form.hotel_stars.value || '—') + '\\nKateqoriyalar: ' + cats.join(', ') + '\\nPilot proqram: ' + (form.querySelector('[name=\"pilot\"]').checked ? 'Bəli' : 'Xeyr') + '\\nQeydlər: ' + (form.notes.value || '—') + basketText);\n  window.open('mailto:micleangroupmmc@gmail.com?subject=' + subject + '&body=' + body);\n  closeM('quote');\n  toast('✓ E-poçt proqramınız açılacaq. Sorğunu göndərin.', 'success');\n  form.reset();\n  document.querySelectorAll('.fcat-item').forEach(function(i) { i.classList.remove('checked'); });\n  btn.disabled = false;\n  btn.classList.remove('loading');\n  btn.textContent = 'Sorğu Göndər';\n}\n\n// ── Subcategory pill data ─────────────────────────────────────────────────────\nvar SUBCATS = {\n  kimyevi:      ['Ümumi & Döşəmə','Dezenfektanlar','Sanitar & HACCP','Xüsusi Kimyəvi Xətt'],\n  camasirxana:  ['Yuyucu Toz','Yuyucu Maye','Yumşaldıcı & Bleach','Dozaj Sistemləri'],\n  metbex:       ['Oven & Grill','Degreaser','Stainless Steel','Qab Yuyucu','HACCP Sanitizer'],\n  amenity:      ['Şampun & Duş Geli','Sabun & Losyon','Dental & Vanity Kit','Terliklər & Ülgüc'],\n  istehlak:     ['Kağız Məhsullar','F&B Qablar','Dispenser & Avadanlıq','PPE & Qoruyucu'],\n  housekeeping: ['Mikrofiber Parça','Mop Sistemləri','Fırça & Süpürgə','Teleskop Saplar'],\n  hovuz:        ['Xlor & OXY','pH · Algisid · Parladıcı']\n};\n\n// Subcategory pill click\nfunction clickPill(subName, catId) {\n  var subs = document.querySelectorAll('#' + catId + ' .sub');\n  var found = null;\n  var keyword = subName.toLowerCase().replace(/ & /g,' ').split(' ')[0];\n  subs.forEach(function(s) {\n    if (!found && s.textContent.toLowerCase().indexOf(keyword) > -1) found = s;\n  });\n  if (found) found.scrollIntoView({ behavior: 'smooth', block: 'start' });\n  else goId(catId);\n  document.querySelectorAll('.spill').forEach(function(p) { p.classList.remove('active'); });\n  if (event && event.target) event.target.classList.add('active');\n}\n\n// Sort change listener\ndocument.getElementById('ssort').addEventListener('change', function() {\n  var q = document.getElementById('sinput').value.trim();\n  if (q) doS(q);\n});\n\n// ── Müqayisə (Compare) ───────────────────────────────────────────────────────\nvar cmpList = [];\n\nfunction toggleCmp(btn) {\n  var pc = btn.closest('.pc');\n  if (!pc) return;\n  var name = pc.querySelector('.pc-name') ? pc.querySelector('.pc-name').textContent.trim() : '';\n  var code = pc.querySelector('.pc-code') ? pc.querySelector('.pc-code').textContent.trim() : '';\n  var imgEl = pc.querySelector('.pc-img');\n  var img = imgEl ? imgEl.src : '';\n  var specs = Array.from(pc.querySelectorAll('.pc-ul li')).map(function(li) { return li.textContent.trim().replace(/^[\\u2014\\-]\\s*/, ''); });\n  var pkg = pc.querySelector('.pc-pkg') ? pc.querySelector('.pc-pkg').textContent.replace('📦 ','').trim() : '—';\n  var del = pc.querySelector('.pc-del') ? pc.querySelector('.pc-del').textContent.trim() : '—';\n  var section = pc.closest('section[id]');\n  var cat = section ? (CATS[section.id] || section.id) : '—';\n  var bdgEl = pc.querySelector('.pc-badges');\n  var badges = bdgEl ? Array.from(bdgEl.querySelectorAll('.bdg')).map(function(b){return b.textContent;}) : [];\n\n  var idx = cmpList.findIndex(function(x) { return x.name === name; });\n  if (idx > -1) {\n    cmpList.splice(idx, 1);\n    btn.classList.remove('in-cmp');\n  } else {\n    if (cmpList.length >= 3) { toast('Maksimum 3 məhsul müqayisə edilə bilər.', 'error'); return; }\n    cmpList.push({ name: name, code: code, img: img, specs: specs, pkg: pkg, del: del, cat: cat, badges: badges });\n    btn.classList.add('in-cmp');\n  }\n  renderCmpBar();\n}\n\nfunction renderCmpBar() {\n  var bar = document.getElementById('cmp-bar');\n  var slotsEl = document.getElementById('cmp-slots');\n  var countEl = document.getElementById('cmp-count');\n  if (!cmpList.length) { bar.classList.remove('open'); return; }\n  bar.classList.add('open');\n  countEl.textContent = cmpList.length + ' / 3';\n  slotsEl.innerHTML = cmpList.map(function(p, i) {\n    return '<div class=\"cmp-slot filled\"><span style=\"overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:120px\">' + p.name.substring(0,22) + (p.name.length>22?'…':'') + '</span>' +\n      '<button class=\"cmp-slot-rm\" onclick=\"removeCmpAt(' + i + ')\" aria-label=\"Sil\">×</button></div>';\n  }).concat(Array(3 - cmpList.length).fill('<div class=\"cmp-slot\">Məhsul seçin...</div>')).join('');\n}\n\nfunction removeCmpAt(i) {\n  var removed = cmpList.splice(i, 1)[0];\n  document.querySelectorAll('.pc-cmp').forEach(function(btn) {\n    var pc = btn.closest('.pc');\n    if (pc && pc.querySelector('.pc-name') && pc.querySelector('.pc-name').textContent.trim() === removed.name) {\n      btn.classList.remove('in-cmp');\n    }\n  });\n  renderCmpBar();\n}\n\nfunction clearCmp() {\n  cmpList = [];\n  document.querySelectorAll('.pc-cmp.in-cmp').forEach(function(b) { b.classList.remove('in-cmp'); });\n  document.getElementById('cmp-bar').classList.remove('open');\n}\n\nfunction openCmp() {\n  if (cmpList.length < 2) { toast('Müqayisə üçün ən azı 2 məhsul seçin.', 'error'); return; }\n  var cols = cmpList;\n  var rows = [\n    { label: 'Məhsul', fn: function(p) {\n      var imgHtml = p.img ? '<img class=\"cmp-img\" src=\"'+p.img+'\" alt=\"'+(p.name||'Məhsul').replace(/\"/g,'&quot;')+'\" onerror=\"this.style.display=\\'none\\'\">' : '<div class=\"cmp-noimg\">🧴</div>';\n      return imgHtml + '<strong style=\"font-size:13px;color:var(--white)\">' + p.name + '</strong>' + (p.code ? '<br><span style=\"font-size:9px;color:var(--gold);letter-spacing:.1em\">' + p.code + '</span>' : '');\n    }},\n    { label: 'Kateqoriya', fn: function(p) { return p.cat; }},\n    { label: 'Badgelər', fn: function(p) { return p.badges.length ? p.badges.map(function(b){ return '<span class=\"bdg bdg-haccp\" style=\"font-size:7px\">' + b + '</span>'; }).join(' ') : '—'; }},\n    { label: 'Spesifikasiya', fn: function(p) { return p.specs.map(function(s){ return '— ' + s; }).join('<br>') || '—'; }},\n    { label: 'Qablaşdırma', fn: function(p) { return p.pkg; }},\n    { label: 'Çatdırılma', fn: function(p) { return p.del; }},\n  ];\n  var thead = '<tr><th></th>' + cols.map(function(p){ return '<th>' + p.name.substring(0,28) + '</th>'; }).join('') + '</tr>';\n  var tbody = rows.map(function(row) {\n    return '<tr><td>' + row.label + '</td>' + cols.map(function(p){ return '<td>' + row.fn(p) + '</td>'; }).join('') + '</tr>';\n  }).join('');\n  document.getElementById('cmp-content').innerHTML = '<table class=\"cmp-tbl\"><thead>' + thead + '</thead><tbody>' + tbody + '</tbody></table>';\n  openM('cmp');\n}\n\n// Inject compare button into every card\ndocument.querySelectorAll('.pc').forEach(function(pc) {\n  var cb = document.createElement('button');\n  cb.className = 'pc-cmp';\n  cb.type = 'button';\n  cb.setAttribute('aria-label', 'Müqayisəyə əlavə et');\n  cb.title = 'Müqayisə';\n  cb.innerHTML = '⇄';\n  cb.addEventListener('click', function(e) { e.stopPropagation(); toggleCmp(cb); });\n  pc.appendChild(cb);\n});\n\n// ── Axtarış tarixi ────────────────────────────────────────────────────────────\nvar HISTORY_KEY = 'mcg_search_history';\nfunction getHistory() {\n  try { return JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]'); } catch(e) { return []; }\n}\nfunction saveHistory(q) {\n  if (!q || q.length < 2) return;\n  var h = getHistory().filter(function(x) { return x !== q; });\n  h.unshift(q);\n  localStorage.setItem(HISTORY_KEY, JSON.stringify(h.slice(0, 6)));\n}\nfunction showHistory() {\n  var h = getHistory();\n  if (!h.length) return;\n  var r = document.getElementById('sres');\n  r.style.display = 'block';\n  r.innerHTML = '<div style=\"padding:8px 14px 4px;font-size:8px;color:var(--muted);letter-spacing:.14em;text-transform:uppercase;display:flex;justify-content:space-between;align-items:center\">Son axtarışlar <span onclick=\"clearHistory()\" style=\"cursor:pointer;color:var(--gold);font-size:8px\">Sil</span></div>' +\n    h.map(function(q) {\n      return '<div class=\"sri\" onclick=\"applyHistory(\\'' + q.replace(/'/g,\"\\\\'\").replace(/</g,'&lt;') + '\\')\" style=\"padding:9px 14px;gap:10px\"><span style=\"color:var(--muted);font-size:13px\">🕐</span><span class=\"sri-name\">' + q.replace(/</g,'&lt;') + '</span></div>';\n    }).join('');\n  document.getElementById('sinput').setAttribute('aria-expanded', 'true');\n}\nfunction applyHistory(q) {\n  var si = document.getElementById('sinput');\n  si.value = q; doS(q);\n}\nfunction clearHistory() {\n  localStorage.removeItem(HISTORY_KEY);\n  hideS();\n}\n\n// Show history on input focus (when empty)\ndocument.getElementById('sinput').addEventListener('focus', function() {\n  if (!this.value.trim()) showHistory();\n});\n\n// Save on search (when user pauses typing and has result)\nvar _origDoS = doS;\ndoS = function(q) {\n  _origDoS(q);\n  if (q && q.length >= 2) saveHistory(q);\n};\n\n// ── Quote basket ──────────────────────────────────────────────────────────────\nvar quoteBasket = [];\nvar _currentPC = null;</script>"}}}