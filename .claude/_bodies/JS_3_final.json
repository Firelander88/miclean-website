{"customEmbed":{"id":"9ac1f9e9-4b4b-4ced-826e-b575663bdd1a","revision":"4","embedData":{"category":"ESSENTIAL","html":"<script>);\n\n// Save on search (when user pauses typing and has result)\nvar _origDoS = doS;\ndoS = function(q) {\n  _origDoS(q);\n  if (q && q.length >= 2) saveHistory(q);\n};\n\n// ── Quote basket ──────────────────────────────────────────────────────────────\nvar quoteBasket = [];\nvar _currentPC = null;\n\nfunction updateBasketCount() {\n  var cnt = document.getElementById('qfloat-cnt');\n  if (quoteBasket.length > 0) {\n    cnt.textContent = quoteBasket.length;\n    cnt.style.display = 'flex';\n  } else {\n    cnt.style.display = 'none';\n  }\n}\n\nfunction addCardToQuote(btn) {\n  var pc = btn.closest('.pc');\n  if (!pc) return;\n  var name = pc.querySelector('.pc-name') ? pc.querySelector('.pc-name').textContent.trim() : '';\n  var code = pc.querySelector('.pc-code') ? pc.querySelector('.pc-code').textContent.trim() : '';\n  var section = pc.closest('section[id]');\n  var cat = section ? section.id : '';\n  var idx = quoteBasket.findIndex(function(x) { return x.name === name; });\n  if (idx === -1) {\n    quoteBasket.push({ name: name, code: code, category: cat });\n    btn.classList.add('added'); btn.textContent = '✓';\n    updateBasketCount();\n    toast('Sorğuya əlavə edildi', 'success');\n  } else {\n    quoteBasket.splice(idx, 1);\n    btn.classList.remove('added'); btn.textContent = '+';\n    updateBasketCount();\n  }\n}\n\nfunction populateQuoteBasket() {\n  var box = document.getElementById('qbasket-box');\n  var list = document.getElementById('qbasket-list');\n  if (!quoteBasket.length) { box.style.display = 'none'; return; }\n  box.style.display = 'block';\n  list.innerHTML = quoteBasket.map(function(item, i) {\n    var safeName = item.name.replace(/</g,'&lt;');\n    var safeCode = item.code ? item.code.replace(/</g,'&lt;') : '';\n    return '<li>' +\n      '<span style=\"flex:1\">' + safeName + '</span>' +\n      (safeCode ? '<span class=\"qb-code\">' + safeCode + '</span>' : '') +\n      '<button class=\"qb-remove\" onclick=\"removeFromBasket(' + i + ')\" title=\"Sil\">&times;</button>' +\n      '</li>';\n  }).join('');\n  // Update title count\n  var titleEl = box.querySelector('.qb-title');\n  var countEl = titleEl.querySelector('.qb-count');\n  if (!countEl) { countEl = document.createElement('span'); countEl.className = 'qb-count'; titleEl.appendChild(countEl); }\n  countEl.textContent = quoteBasket.length;\n  // Auto-check matching categories\n  var cats = quoteBasket.map(function(x) { return x.category; }).filter(Boolean);\n  document.querySelectorAll('#qform input[name=\"cats\"]').forEach(function(cb) {\n    if (cats.indexOf(cb.value) > -1) {\n      cb.checked = true;\n      cb.closest('.fcat-item').classList.add('checked');\n    }\n  });\n  // Auto-fill notes with product list\n  var notesEl = document.querySelector('#qform textarea[name=\"notes\"]');\n  if (notesEl && !notesEl.value) {\n    notesEl.value = 'Seçilmiş məhsullar:\\n' + quoteBasket.map(function(x, i) {\n      return (i + 1) + '. ' + x.name + (x.code ? ' (' + x.code + ')' : '');\n    }).join('\\n');\n  }\n}\n\nfunction removeFromBasket(idx) {\n  quoteBasket.splice(idx, 1);\n  updateBasketCount();\n  populateQuoteBasket();\n  // Update card button states\n  document.querySelectorAll('.pc-add.added').forEach(function(btn) {\n    var pc = btn.closest('.pc');\n    var name = pc.querySelector('.pc-name') ? pc.querySelector('.pc-name').textContent.trim() : '';\n    if (!quoteBasket.some(function(x) { return x.name === name; })) {\n      btn.classList.remove('added'); btn.textContent = '+';\n    }\n  });\n}\n\n// ── Product detail modal ──────────────────────────────────────────────────────\nfunction openDetail(pc) {\n  _currentPC = pc;\n  var code = pc.querySelector('.pc-code') ? pc.querySelector('.pc-code').textContent.trim() : '';\n  var name = pc.querySelector('.pc-name') ? pc.querySelector('.pc-name').textContent.trim() : '';\n  var imgEl = pc.querySelector('.pc-img');\n  var img = imgEl ? imgEl.src : '';\n  var imgAlt = imgEl ? (imgEl.getAttribute('alt') || '') : '';\n  var specs = Array.from(pc.querySelectorAll('.pc-ul li')).map(function(li) {\n    return li.textContent.trim().replace(/^[\\u2014\\-]\\s*/, '');\n  });\n  var pkg = pc.querySelector('.pc-pkg') ? pc.querySelector('.pc-pkg').textContent.trim() : '';\n  var del = pc.querySelector('.pc-del') ? pc.querySelector('.pc-del').textContent.trim() : '';\n  var bdgEl = pc.querySelector('.pc-badges');\n  var bdgHtml = bdgEl ? '<div style=\"display:flex;gap:5px;flex-wrap:wrap;margin-bottom:12px\">' + bdgEl.innerHTML + '</div>' : '';\n  var imgHtml = img\n    ? '<img class=\"dm-img\" src=\"' + img + '\" alt=\"' + imgAlt.replace(/\"/g,'&quot;') + '\" loading=\"lazy\" onerror=\"this.parentElement.innerHTML=\\'<div class=dm-noimg>&#129529;</div>\\'\">'\n    : '<div class=\"dm-noimg\">🧴</div>';\n  var specsHtml = specs.length\n    ? '<ul class=\"dm-specs\">' + specs.map(function(s) { return '<li>' + s.replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</li>'; }).join('') + '</ul>'\n    : '';\n  var rowsHtml = '';\n  if (pkg) rowsHtml += '<div class=\"dm-row\"><span class=\"dm-label\">Qablaşdırma</span><span class=\"dm-val\">' + pkg.replace('📦 ','') + '</span></div>';\n  if (del) rowsHtml += '<div class=\"dm-row\"><span class=\"dm-label\">Çatdırılma</span><span class=\"dm-val\">' + del + '</span></div>';\n  var section = pc.closest('section[id]');\n  var cat = section ? section.id : '';\n  if (cat && CATS[cat]) rowsHtml += '<div class=\"dm-row\"><span class=\"dm-label\">Kateqoriya</span><span class=\"dm-val\">' + CATS[cat] + '</span></div>';\n  document.getElementById('dm-body').innerHTML =\n    '<div class=\"dm-side\">' + imgHtml + '</div>' +\n    '<div class=\"dm-info\">' +\n      bdgHtml +\n      (code ? '<div class=\"dm-code\">' + code.replace(/</g,'&lt;') + '</div>' : '') +\n      '<div class=\"dm-name\">' + name.replace(/</g,'&lt;') + '</div>' +\n      specsHtml +\n      (rowsHtml ? '<div style=\"margin-top:14px\">' + rowsHtml + '</div>' : '') +\n    '</div>';\n  var addBtn = document.getElementById('dm-add-btn');\n  var inBasket = quoteBasket.some(function(x) { return x.name === name; });\n  if (inBasket) { addBtn.textContent = '✓ Sorğuda var'; addBtn.classList.add('dm-added'); }\n  else { addBtn.textContent = '+ Sorğuya Əlavə Et'; addBtn.classList.remove('dm-added'); }\n  var title = name.length > 35 ? name.substring(0, 32) + '…' : name;\n  document.getElementById('modal-detail-title').textContent = title;\n  openM('detail');\n}\n\nfunction addCurrentToQuote() {\n  if (!_currentPC) return;\n  var name = _currentPC.querySelector('.pc-name') ? _currentPC.querySelector('.pc-name').textContent.trim() : '';\n  var code = _currentPC.querySelector('.pc-code') ? _currentPC.querySelector('.pc-code').textContent.trim() : '';\n  var section = _currentPC.closest('section[id]');\n  var cat = section ? section.id : '';\n  var idx = quoteBasket.findIndex(function(x) { return x.name === name; });\n  var addBtn = document.getElementById('dm-add-btn');\n  var cardBtn = _currentPC.querySelector('.pc-add');\n  if (idx === -1) {\n    quoteBasket.push({ name: name, code: code, category: cat });\n    addBtn.textContent = '✓ Sorğuda var'; addBtn.classList.add('dm-added');\n    if (cardBtn) { cardBtn.classList.add('added'); cardBtn.textContent = '✓'; }\n    updateBasketCount();\n    toast('Sorğuya əlavə edildi', 'success');\n  } else {\n    quoteBasket.splice(idx, 1);\n    addBtn.textContent = '+ Sorğuya Əlavə Et'; addBtn.classList.remove('dm-added');\n    if (cardBtn) { cardBtn.classList.remove('added'); cardBtn.textContent = '+'; }\n    updateBasketCount();\n    toast('Sorğudan çıxarıldı', '');\n  }\n}\n\n// ── Product card injection (badges + add buttons) ─────────────────────────────\nvar BADGE_HACCP = ['haccp','food-grade','food-safe'];\nvar BADGE_ECO   = [' eco','bio ','compostable','xlorsuz'];\ndocument.querySelectorAll('.pc').forEach(function(pc) {\n  // + button\n  var ab = document.createElement('button');\n  ab.className = 'pc-add'; ab.type = 'button';\n  ab.setAttribute('aria-label', 'Sorğuya əlavə et');\n  ab.textContent = '+';\n  pc.appendChild(ab);\n  // badges\n  var code = (pc.querySelector('.pc-code') ? pc.querySelector('.pc-code').textContent : '').toLowerCase();\n  var name = (pc.querySelector('.pc-name') ? pc.querySelector('.pc-name').textContent : '').toLowerCase();\n  var combined = code + ' ' + name;\n  var bdgs = [];\n  if (BADGE_HACCP.some(function(k) { return combined.indexOf(k) > -1; }))\n    bdgs.push('<span class=\"bdg bdg-haccp\">HACCP</span>');\n  if (BADGE_ECO.some(function(k) { return combined.indexOf(k) > -1; }))\n    bdgs.push('<span class=\"bdg bdg-eco\">ECO</span>');\n  if (bdgs.length) {\n    var bd = document.createElement('div');\n    bd.className = 'pc-badges'; bd.innerHTML = bdgs.join('');\n    pc.appendChild(bd);\n  }\n  pc.style.cursor = 'pointer';\n});\n\n// ── Table row actions (+ add to quote, compare) ─────────────────────────────\ndocument.querySelectorAll('.tbl').forEach(function(tbl) {\n  var section = tbl.closest('section[id]');\n  var cat = section ? section.id : '';\n  // Add header column\n  var thead = tbl.querySelector('thead tr');\n  if (thead) {\n    var th = document.createElement('th');\n    th.textContent = '';\n    th.style.width = '80px';\n    thead.appendChild(th);\n  }\n  // Add action buttons to each body row\n  tbl.querySelectorAll('tbody tr').forEach(function(tr) {\n    var nameCell = tr.querySelector('.tn');\n    if (!nameCell) return;\n    var name = nameCell.textContent.trim();\n    var td = document.createElement('td');\n    td.innerHTML = '<div class=\"tbl-actions\">' +\n      '<button class=\"tbl-add\" title=\"Sorğuya əlavə et\" data-name=\"' + name.replace(/\"/g,'&quot;') + '\" data-cat=\"' + cat + '\">+</button>' +\n      '<button class=\"tbl-cmp\" title=\"Müqayisə\" data-name=\"' + name.replace(/\"/g,'&quot;') + '\">⇄</button>' +\n      '</div>';\n    tr.appendChild(td);\n  });\n});\n\n// Event delegation for card + table clicks\ndocument.addEventListener('click', function(e) {\n  // Table add button\n  var tblAdd = e.target.closest('.tbl-add');\n  if (tblAdd) {\n    e.stopPropagation();\n    var name = tblAdd.dataset.name;\n    var cat = tblAdd.dataset.cat;\n    var idx = quoteBasket.findIndex(function(x) { return x.name === name; });\n    if (idx === -1) {\n      quoteBasket.push({ name: name, code: '', category: cat });\n      tblAdd.classList.add('added'); tblAdd.textContent = '✓';\n      updateBasketCount();\n      toast('Sorğuya əlavə edildi: ' + name, 'success');\n    } else {\n      quoteBasket.splice(idx, 1);\n      tblAdd.classList.remove('added'); tblAdd.textContent = '+';\n      updateBasketCount();\n      toast('Sorğudan çıxarıldı', '');\n    }\n    return;\n  }\n  // Table compare button\n  var tblCmp = e.target.closest('.tbl-cmp');\n  if (tblCmp) {\n    e.stopPropagation();\n    var name = tblCmp.dataset.name;\n    var tr = tblCmp.closest('tr');\n    var cells = tr.querySelectorAll('td');\n    var specs = [];\n    cells.forEach(function(c, i) { if (i > 0 && !c.querySelector('.tbl-actions')) specs.push(c.textContent.trim()); });\n    // Add to compare\n    if (typeof cmpItems !== 'undefined' && cmpItems.length < 3) {\n      var already = cmpItems.some(function(x) { return x.name === name; });\n      if (!already) {\n        cmpItems.push({ name: name, code: '', specs: specs, img: null });\n        tblCmp.classList.add('in-cmp');\n        updateCmpBar();\n        toast('Müqayisəyə əlavə edildi: ' + name, 'success');\n      }\n    }\n    return;\n  }\n  var ab = e.target.closest('.pc-add');\n  if (ab) { e.stopPropagation(); addCardToQuote(ab); return; }\n  var pc = e.target.closest('.pc');\n  if (pc) openDetail(pc);\n});\n\n// ── Section TOC indicator ──────────────────────────────────────────────────\n(function() {\n  var toc = document.getElementById('sec-toc');\n  if (!toc) return;\n  var dots = Array.from(toc.querySelectorAll('.toc-dot'));\n  var secs = dots.map(function(d) {\n    return document.getElementById(d.dataset.sec);\n  });\n\n  var tocSections = ['kimyevi','camasirxana','metbex','amenity','istehlak','housekeeping','hovuz'];\n  var firstSecTop = 0;\n  var firstSec = document.getElementById(tocSections[0]);\n  if (firstSec) firstSecTop = firstSec.getBoundingClientRect().top + window.scrollY - 200;\n\n  function updateToc() {\n    var scrollY = window.scrollY;\n    var winH = window.innerHeight;\n\n    // Show/hide TOC: show only when first catalog section is near view\n    var inCatalog = scrollY >= firstSecTop;\n    toc.classList.toggle('show', inCatalog);\n\n    // Find active section\n    var active = -1;\n    secs.forEach(function(sec, i) {\n      if (!sec) return;\n      var top = sec.getBoundingClientRect().top + scrollY;\n      if (scrollY >= top - winH * 0.4) active = i;\n    });\n\n    dots.forEach(function(d, i) {\n      d.classList.toggle('active', i === active);\n    });\n  }\n\n  window.addEventListener('scroll', updateToc, { passive: true });\n  updateToc();\n})();\n\n// ── Print / PDF catalog ────────────────────────────────────────────────────\nfunction printCatalog() {\n  // Update print date\n  var meta = document.getElementById('ph-meta');\n  if (meta) {\n    var now = new Date();\n    var months = ['Yanvar','Fevral','Mart','Aprel','May','İyun','İyul','Avqust','Sentyabr','Oktyabr','Noyabr','Dekabr'];\n    meta.textContent = 'Çap tarixi: ' + now.getDate() + ' ' + months[now.getMonth()] + ' ' + now.getFullYear();\n  }\n  // Count visible cards for user feedback\n  var visible = document.querySelectorAll('.pc:not(.hidden)').length;\n  var total = document.querySelectorAll('.pc').length;\n  var msg = visible < total\n    ? 'Hal-hazırda ' + visible + ' məhsul süzülüb. Yalnız bunlar çap ediləcək. Davam edirsiniz?'\n    : null;\n  if (msg && !confirm(msg)) return;\n  window.print();\n}\n\n// ── FAQ accordion toggle ────────────────────────────────────────────────────\nfunction toggleFaq(btn) {\n  var item = btn.closest('.faq-item');\n  // Close other open items\n  document.querySelectorAll('.faq-item.open').forEach(function(el) {\n    if (el !== item) { el.classList.remove('open'); el.querySelector('.faq-q').setAttribute('aria-expanded','false'); }\n  });\n  item.classList.toggle('open');\n  btn.setAttribute('aria-expanded', item.classList.contains('open'));\n}\n\n// ── Cookie consent ──────────────────────────────────────────────────────────\n(function() {\n  if (!localStorage.getItem('mi-cookie-consent')) {\n    setTimeout(function() {\n      var banner = document.getElementById('cookie-banner');\n      if (banner) banner.classList.add('show');\n    }, 1500);\n  }\n})();\nfunction acceptCookies() {\n  localStorage.setItem('mi-cookie-consent', 'accepted');\n  document.getElementById('cookie-banner').classList.remove('show');\n}\nfunction declineCookies() {\n  localStorage.setItem('mi-cookie-consent', 'declined');\n  document.getElementById('cookie-banner').classList.remove('show');\n}</script>"}}}