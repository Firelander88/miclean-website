{"customEmbed": {"name": "MI CLEAN JS 3", "enabled": true, "loadOnce": false, "position": "BODY_END", "embedData": {"category": "ESSENTIAL", "html": "<script>\n// \u2500\u2500 Product card injection (badges + add buttons) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nvar BADGE_HACCP = ['haccp','food-grade','food-safe'];\nvar BADGE_ECO   = [' eco','bio ','compostable','xlorsuz'];\ndocument.querySelectorAll('.pc').forEach(function(pc) {\n  // + button\n  var ab = document.createElement('button');\n  ab.className = 'pc-add'; ab.type = 'button';\n  ab.setAttribute('aria-label', 'Sor\u011fuya \u0259lav\u0259 et');\n  ab.textContent = '+';\n  pc.appendChild(ab);\n  // badges\n  var code = (pc.querySelector('.pc-code') ? pc.querySelector('.pc-code').textContent : '').toLowerCase();\n  var name = (pc.querySelector('.pc-name') ? pc.querySelector('.pc-name').textContent : '').toLowerCase();\n  var combined = code + ' ' + name;\n  var bdgs = [];\n  if (BADGE_HACCP.some(function(k) { return combined.indexOf(k) > -1; }))\n    bdgs.push('<span class=\"bdg bdg-haccp\">HACCP</span>');\n  if (BADGE_ECO.some(function(k) { return combined.indexOf(k) > -1; }))\n    bdgs.push('<span class=\"bdg bdg-eco\">ECO</span>');\n  if (bdgs.length) {\n    var bd = document.createElement('div');\n    bd.className = 'pc-badges'; bd.innerHTML = bdgs.join('');\n    pc.appendChild(bd);\n  }\n  pc.style.cursor = 'pointer';\n});\n\n// Event delegation for card clicks\ndocument.addEventListener('click', function(e) {\n  var ab = e.target.closest('.pc-add');\n  if (ab) { e.stopPropagation(); addCardToQuote(ab); return; }\n  var pc = e.target.closest('.pc');\n  if (pc) openDetail(pc);\n});\n\n// \u2500\u2500 Section TOC indicator \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n(function() {\n  var toc = document.getElementById('sec-toc');\n  if (!toc) return;\n  var dots = Array.from(toc.querySelectorAll('.toc-dot'));\n  var secs = dots.map(function(d) {\n    return document.getElementById(d.dataset.sec);\n  });\n\n  var tocSections = ['kimyevi','camasirxana','metbex','amenity','istehlak','housekeeping','hovuz'];\n  var firstSecTop = 0;\n  var firstSec = document.getElementById(tocSections[0]);\n  if (firstSec) firstSecTop = firstSec.getBoundingClientRect().top + window.scrollY - 200;\n\n  function updateToc() {\n    var scrollY = window.scrollY;\n    var winH = window.innerHeight;\n\n    // Show/hide TOC: show only when first catalog section is near view\n    var inCatalog = scrollY >= firstSecTop;\n    toc.classList.toggle('show', inCatalog);\n\n    // Find active section\n    var active = -1;\n    secs.forEach(function(sec, i) {\n      if (!sec) return;\n      var top = sec.getBoundingClientRect().top + scrollY;\n      if (scrollY >= top - winH * 0.4) active = i;\n    });\n\n    dots.forEach(function(d, i) {\n      d.classList.toggle('active', i === active);\n    });\n  }\n\n  window.addEventListener('scroll', updateToc, { passive: true });\n  updateToc();\n})();\n\n// \u2500\u2500 Print / PDF catalog \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nfunction printCatalog() {\n  // Update print date\n  var meta = document.getElementById('ph-meta');\n  if (meta) {\n    var now = new Date();\n    var months = ['Yanvar','Fevral','Mart','Aprel','May','\u0130yun','\u0130yul','Avqust','Sentyabr','Oktyabr','Noyabr','Dekabr'];\n    meta.textContent = '\u00c7ap tarixi: ' + now.getDate() + ' ' + months[now.getMonth()] + ' ' + now.getFullYear();\n  }\n  // Count visible cards for user feedback\n  var visible = document.querySelectorAll('.pc:not(.hidden)').length;\n  var total = document.querySelectorAll('.pc').length;\n  var msg = visible < total\n    ? 'Hal-haz\u0131rda ' + visible + ' m\u0259hsul s\u00fcz\u00fcl\u00fcb. Yaln\u0131z bunlar \u00e7ap edil\u0259c\u0259k. Davam edirsiniz?'\n    : null;\n  if (msg && !confirm(msg)) return;\n  window.print();\n}</script>"}}}