# Normalize line endings for all text files
* text=auto

# Force LF for scripts/configs
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.conf  text eol=lf
*.env*  text eol=lf

# Binary files — no line ending conversion
*.sqlite3  binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.eot      binary
