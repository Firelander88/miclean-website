"<style>\n*{margin:0;padding:0;box-sizing:border-box}\n:root{--pri:#0a2351;--acc:#1a73e8;--bg:#f5f7fa;--card:#fff;--txt:#1a1a2e;--sub:#5f6368;--brd:#e0e3e8;--r:12px;--sh:0 2px 12px rgba(0,0,0,.08)}\nbody{font-family:'Segoe UI',system-ui,-apple-system,sans-serif;background:var(--bg);color:var(--txt);line-height:1.5}\n.hdr{background:linear-gradient(135deg,var(--pri) 0%,#143a7a 100%);color:#fff;padding:28px 24px 20px;text-align:center}\n.hdr h1{font-size:22px;font-weight:700;letter-spacing:.5px;margin-bottom:4px}\n.hdr p{font-size:13px;opacity:.8}\n.bar{background:#fff;padding:12px 16px;position:sticky;top:0;z-index:10;box-shadow:var(--sh);display:flex;gap:8px;flex-wrap:wrap;align-items:center}\n.bar input{flex:1;min-width:180px;padding:10px 14px;border:1.5px solid var(--brd);border-radius:var(--r);font-size:14px;outline:none;transition:border .2s}\n.bar input:focus{border-color:var(--acc)}\n.bar select{padding:10px 12px;border:1.5px solid var(--brd);border-radius:var(--r);font-size:13px;background:#fff;outline:none;cursor:pointer;max-width:200px}\n.bar select:focus{border-color:var(--acc)}\n.cnt{display:flex;gap:8px;padding:8px 12px;overflow-x:auto;background:#fff;border-bottom:1px solid var(--brd)}\n.cnt::-webkit-scrollbar{height:0}\n.chip{padding:6px 14px;border-radius:20px;font-size:12px;font-weight:500;cursor:pointer;white-space:nowrap;border:1.5px solid var(--brd);background:#fff;color:var(--sub);transition:all .2s}\n.chip:hover{border-color:var(--acc);color:var(--acc)}\n.chip.on{background:var(--acc);color:#fff;border-color:var(--acc)}\n.stats{padding:10px 16px;font-size:13px;color:var(--sub);display:flex;justify-content:space-between;align-items:center}\n.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;padding:0 16px 24px}\n.card{background:var(--card);border-radius:var(--r);overflow:hidden;box-shadow:var(--sh);transition:transform .2s,box-shadow .2s;cursor:pointer;border:1px solid transparent}\n.card:hover{transform:translateY(-3px);box-shadow:0 6px 24px rgba(0,0,0,.12);border-color:var(--acc)}\n.cimg{height:140px;background:linear-gradient(135deg,#e8edf5 0%,#f0f4f8 100%);display:flex;align-items:center;justify-content:center;position:relative}\n.cimg .ico{font-size:40px;opacity:.4}\n.badge{position:absolute;top:8px;left:8px;background:var(--pri);color:#fff;font-size:10px;padding:3px 8px;border-radius:4px;font-weight:600}\n.cbody{padding:14px}\n.cbody h3{font-size:14px;font-weight:600;line-height:1.3;margin-bottom:6px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}\n.cbody .kod{font-size:11px;color:var(--acc);font-weight:600;margin-bottom:6px}\n.cbody .cat{font-size:11px;color:var(--sub);margin-bottom:8px}\n.tags{display:flex;flex-wrap:wrap;gap:4px}\n.tag{font-size:10px;padding:3px 8px;background:#e8f0fe;color:var(--acc);border-radius:4px;font-weight:500}\n.empty{text-align:center;padding:60px 20px;color:var(--sub)}\n.empty .ei{font-size:48px;margin-bottom:12px;opacity:.3}\n.empty p{font-size:15px}\n.load{text-align:center;padding:80px 20px}\n.spinner{width:40px;height:40px;border:3px solid var(--brd);border-top-color:var(--acc);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 16px}\n@keyframes spin{to{transform:rotate(360deg)}}\n.load p{color:var(--sub);font-size:14px}\n.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:100;align-items:center;justify-content:center;padding:20px}\n.modal-bg.show{display:flex}\n.modal{background:#fff;border-radius:var(--r);max-width:500px;width:100%;max-height:80vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.3)}\n.mhdr{padding:20px;border-bottom:1px solid var(--brd);display:flex;justify-content:space-between;align-items:start}\n.mhdr h2{font-size:17px;font-weight:700;flex:1;padding-right:12px}\n.mclose{width:32px;height:32px;border:none;background:var(--bg);border-radius:50%;cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center}\n.mbody{padding:20px}\n.mrow{display:flex;margin-bottom:12px;font-size:13px}\n.mrow .ml{width:110px;color:var(--sub);flex-shrink:0;font-weight:500}\n.mrow .mv{flex:1;font-weight:400}\n.mvars{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px}\n.mvar{padding:6px 14px;background:var(--bg);border-radius:8px;font-size:13px;font-weight:500;border:1.5px solid var(--brd)}\n.mcta{display:block;margin-top:20px;padding:12px;background:var(--acc);color:#fff;text-align:center;border:none;border-radius:var(--r);font-size:14px;font-weight:600;cursor:pointer;width:100%;transition:background .2s}\n.mcta:hover{background:#1557b0}\n@media(max-width:600px){.grid{grid-template-columns:1fr 1fr;gap:10px;padding:0 10px 20px}.hdr{padding:20px 16px 16px}.hdr h1{font-size:18px}.card .cimg{height:100px}.cbody{padding:10px}.cbody h3{font-size:13px}}\n@media(max-width:400px){.grid{grid-template-columns:1fr}}\n</style>\n\n<div class=\"hdr\">\n<h1>MI CLEAN GROUP — Məhsul Kataloqu</h1>\n<p>Peşəkar təmizlik və gigiyena həlləri</p>\n</div>\n<div class=\"bar\">\n<input type=\"text\" id=\"q\" placeholder=\"Məhsul axtar... (ad, kod, kateqoriya)\">\n<select id=\"fCat\"><option value=\"\">Bütün kateqoriyalar</option></select>\n<select id=\"fSub\"><option value=\"\">Bütün alt kateqoriyalar</option></select>\n</div>\n<div class=\"cnt\" id=\"chips\"></div>\n<div class=\"stats\" id=\"stats\"></div>\n<div id=\"main\">\n<div class=\"load\"><div class=\"spinner\"></div><p>Kataloq yüklənir...</p></div>\n</div>\n<div class=\"modal-bg\" id=\"mbg\">\n<div class=\"modal\">\n<div class=\"mhdr\"><h2 id=\"mt\"></h2><button class=\"mclose\" id=\"mc\">&times;</button></div>\n<div class=\"mbody\" id=\"mbd\"></div>\n</div>\n</div>\n\n<script>\nlet P=[],chunks=0,curCat='',curSub='',curQ='';\nconst catIcons={'Kimyəvi Təmizlik Vasitələri':'🧪','Camaşırxana Məhsulları':'👔','Mətbəx Gigiyena Məhsulları':'🍽️','Hotel Amenity':'🏨','Housekeeping Alətləri':'🧹','Hovuz Təmizliyi':'🏊','İstehlak Materialları':'📦'};\n\nwindow.addEventListener('message',function(e){\nif(e.data&&e.data.type==='mcData'){\nP=P.concat(e.data.data);chunks++;\nif(chunks>=e.data.total)init();\n}\n});\n\nfunction init(){\nP.sort((a,b)=>a.c.localeCompare(b.c)||a.s.localeCompare(b.s)||a.t.localeCompare(b.t));\nbuildFilters();render();\n}\n\nfunction buildFilters(){\nconst cats=[...new Set(P.map(p=>p.c))].sort();\nconst fc=document.getElementById('fCat');\ncats.forEach(c=>{const o=document.createElement('option');o.value=c;o.textContent=c+' ('+P.filter(p=>p.c===c).length+')';fc.appendChild(o)});\n\n// chips\nconst ch=document.getElementById('chips');\nconst allChip=document.createElement('span');\nallChip.className='chip on';allChip.textContent='Hamısı ('+P.length+')';\nallChip.onclick=function(){curCat='';curSub='';document.getElementById('fCat').value='';document.getElementById('fSub').value='';\ndocument.querySelectorAll('.chip').forEach(c=>c.classList.remove('on'));this.classList.add('on');render()};\nch.appendChild(allChip);\n\ncats.forEach(c=>{\nconst chip=document.createElement('span');\nchip.className='chip';chip.textContent=(catIcons[c]||'📋')+' '+c.split(' ')[0];\nchip.onclick=function(){curCat=c;curSub='';document.getElementById('fCat').value=c;updateSubs();\ndocument.querySelectorAll('.chip').forEach(x=>x.classList.remove('on'));this.classList.add('on');render()};\nch.appendChild(chip);\n});\n\ndocument.getElementById('fCat').onchange=function(){curCat=this.value;curSub='';updateSubs();render();\ndocument.querySelectorAll('.chip').forEach(x=>x.classList.remove('on'));\nif(!curCat)ch.firstChild.classList.add('on');\n};\ndocument.getElementById('fSub').onchange=function(){curSub=this.value;render()};\ndocument.getElementById('q').oninput=function(){curQ=this.value.toLowerCase().trim();render()};\ndocument.getElementById('mc').onclick=function(){document.getElementById('mbg').classList.remove('show')};\ndocument.getElementById('mbg').onclick=function(e){if(e.target===this)this.classList.remove('show')};\n}\n\nfunction updateSubs(){\nconst fs=document.getElementById('fSub');\nfs.innerHTML='<option value=\"\">Bütün alt kateqoriyalar</option>';\nif(!curCat)return;\nconst subs=[...new Set(P.filter(p=>p.c===curCat).map(p=>p.s))].sort();\nsubs.forEach(s=>{const o=document.createElement('option');o.value=s;o.textContent=s;fs.appendChild(o)});\n}\n\nfunction render(){\nconst f=P.filter(p=>{\nif(curCat&&p.c!==curCat)return false;\nif(curSub&&p.s!==curSub)return false;\nif(curQ){const h=(p.t+' '+p.k+' '+p.c+' '+p.s+(p.v||'')).toLowerCase();if(!h.includes(curQ))return false;}\nreturn true;\n});\ndocument.getElementById('stats').innerHTML='<span>'+f.length+' məhsul tapıldı</span><span>Ümumi: '+P.length+' məhsul</span>';\n\nif(!f.length){\ndocument.getElementById('main').innerHTML='<div class=\"empty\"><div class=\"ei\">🔍</div><p>Heç bir məhsul tapılmadı</p></div>';\nreturn;\n}\n\nlet h='<div class=\"grid\">';\nf.forEach((p,i)=>{\nconst icon=catIcons[p.c]||'📋';\nconst vars=p.v?p.v.split(' / ').map(v=>'<span class=\"tag\">'+esc(v)+'</span>').join(''):'';\nh+='<div class=\"card\" data-i=\"'+i+'\" onclick=\"showDetail(this)\"><div class=\"cimg\"><span class=\"ico\">'+icon+'</span>'\n+'<span class=\"badge\">'+esc(p.k)+'</span></div><div class=\"cbody\"><h3>'+esc(p.t)+'</h3>'\n+'<div class=\"kod\">'+esc(p.k)+'</div><div class=\"cat\">'+esc(p.s)+'</div>'\n+(vars?'<div class=\"tags\">'+vars+'</div>':'')+'</div></div>';\n});\nh+='</div>';\ndocument.getElementById('main').innerHTML=h;\n// Store filtered data for detail view\nwindow._filt=f;\n}\n\nwindow.showDetail=function(el){\nconst p=window._filt[+el.dataset.i];if(!p)return;\ndocument.getElementById('mt').textContent=p.t;\nlet b='<div class=\"mrow\"><div class=\"ml\">Kod:</div><div class=\"mv\">'+esc(p.k)+'</div></div>'\n+'<div class=\"mrow\"><div class=\"ml\">Kateqoriya:</div><div class=\"mv\">'+esc(p.c)+'</div></div>'\n+'<div class=\"mrow\"><div class=\"ml\">Alt kateqoriya:</div><div class=\"mv\">'+esc(p.s)+'</div></div>';\nif(p.v){\nb+='<div style=\"margin-top:16px;font-size:13px;font-weight:600;color:var(--pri)\">Mövcud variantlar:</div><div class=\"mvars\">';\np.v.split(' / ').forEach(v=>{b+='<span class=\"mvar\">'+esc(v)+'</span>'});\nb+='</div>';\n}\nb+='<button class=\"mcta\" onclick=\"window.parent.postMessage({type:\\'mcQuote\\',product:\\''+esc(p.t)+'\\'},\\'*\\')\">Qiymət sorğusu göndər</button>';\ndocument.getElementById('mbd').innerHTML=b;\ndocument.getElementById('mbg').classList.add('show');\n};\n\nfunction esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');}\n</script>"